    {
      "name": "Webhooks (Public)",
      "item": [
        {
          "name": "GitHub Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-GitHub-Event",
                "value": "push"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ref\": \"refs/heads/main\",\n  \"before\": \"abc123\",\n  \"after\": \"def456\",\n  \"repository\": {\n    \"name\": \"my-app\",\n    \"full_name\": \"user/my-app\"\n  },\n  \"pusher\": {\n    \"name\": \"john-doe\"\n  }\n}"
            },
