{
  "info": {
    "name": "AGL Hostman API",
    "description": "Postman collection for AGL Hostman API testing",
    "version": "3.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.agl.hostman/api"
    },
    {
      "key": "api_token",
      "value": ""
    },
    {
      "key": "workflow_id",
      "value": "example-workflow"
    },
    {
      "key": "container_id",
      "value": "123"
    },
    {
      "key": "project_id",
      "value": "my-app"
    },
    {
      "key": "application_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/user",
              "protocol": "https",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "user"
              ]
            },
            "description": "Get the current authenticated user's profile and permissions"
          },
          "response": []
        },
        {
          "name": "WorkOS Redirect",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/workos/redirect",
              "protocol": "https",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "workos",
                "redirect"
              ]
            },
            "description": "Redirect to WorkOS for OAuth authentication"
          },
          "response": []
        },
        {
          "name": "WorkOS Callback",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/workos/callback?code=YOUR_AUTH_CODE",
              "protocol": "https",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "workos",
                "callback"
              ],
              "query": [
                {
                  "key": "code",
                  "value": "YOUR_AUTH_CODE",
                  "description": "Authorization code from WorkOS"
                }
              ]
            },
            "description": "Handles the callback from WorkOS after authentication"
          },
          "response": []
        }
      ]
    },
    {
      "name": "N8N Workflow Management",
      "item": [
        {
          "name": "List Workflows",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
