# Telegram (https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Opcional: sessão serializada (StringSession) para deploy sem ficheiro .session
TELEGRAM_SESSION_STRING=

# Canais/grupos a monitorizar (separados por vírgula)
# Público: @nome_canal | Privado: ID numérico (ver scripts/list_groups.py)
# Descobrir tipo (canal vs grupo) e fallback t.me/s/: scripts/classify_chats.py
TELEGRAM_MONITOR_CHATS=@mmpromo,@pcdofafapromo,@tecnoarthardware,@opczaopromocoes,@amandapromos

# Base de dados local
DATABASE_PATH=data/pc_gamer.sqlite3

# Margem padrão sobre custo de peças (percentual)
DEFAULT_MARGIN_PERCENT=15

# Mercado Livre — token opcional (API pública MLB/search, já só vendedores BR)
MERCADOLIVRE_ACCESS_TOKEN=
# true = só lojas oficiais; false = todos os vendedores do Brasil
MERCADOLIVRE_ONLY_OFFICIAL=false

# AliExpress Affiliate IOP — https://portals.aliexpress.com/
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_TRACKING_ID=
# País de envio/destino: BR prioriza armazém Brasil (entrega rápida, menos taxa)
ALIEXPRESS_SHIP_FROM=BR

# Providers ativos na automação fetch-market (separados por vírgula)
# Disponíveis: mercadolivre, pichau, aliexpress, 4gamers
MARKET_FETCH_PROVIDERS=mercadolivre,pichau,aliexpress,4gamers

# Scraper t.me/s/ (sem Telethon)
TME_SYNC_LIMIT=20
# Revalidação de ofertas (estoque/preço no link)
OFFER_VALIDATION_MAX_AGE_HOURS=72
OFFER_REVALIDATE_MINUTES=30
OFFER_VALIDATION_BATCH=25
OFFER_PRICE_TOLERANCE_PERCENT=5
