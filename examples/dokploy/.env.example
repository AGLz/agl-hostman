# Environment Variables for agl-hostman on Dokploy
# Copy this file to .env and fill in the values
# IMPORTANT: Never commit .env file to git

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Application version (used in production)
VERSION=latest

# ============================================
# Proxmox API Configuration
# ============================================
PROXMOX_API_URL=https://192.168.0.245:8006/api2/json
PROXMOX_API_TOKEN_ID=your-token-id@pam!your-token-name
PROXMOX_API_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_VERIFY_SSL=false

# ============================================
# WireGuard Configuration
# ============================================
WIREGUARD_INTERFACE=wg0
WIREGUARD_CONFIG_PATH=/etc/wireguard/wg0.conf

# ============================================
# Network Configuration
# ============================================
LAN_NETWORK=192.168.0.0/24
WG_NETWORK=10.6.0.0/24

# ============================================
# Database Configuration (if needed)
# ============================================
# DB_USER=agl_user
# DB_PASSWORD=secure_password_here
# DB_NAME=agl_hostman
# DB_HOST=postgres
# DB_PORT=5432
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ============================================
# Redis Configuration (if needed)
# ============================================
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ============================================
# Monitoring & Metrics (Production)
# ============================================
# ENABLE_METRICS=true
# METRICS_PORT=9090

# ============================================
# Security Configuration (Production)
# ============================================
# RATE_LIMIT_ENABLED=true
# MAX_REQUESTS_PER_MINUTE=100
# JWT_SECRET=your-jwt-secret-here
# SESSION_SECRET=your-session-secret-here

# ============================================
# Logging Configuration
# ============================================
# LOG_FORMAT=json
# LOG_FILE=/app/logs/app.log
# ERROR_LOG_FILE=/app/logs/error.log

# ============================================
# Feature Flags
# ============================================
# FEATURE_WIREGUARD_MANAGEMENT=true
# FEATURE_CONTAINER_MANAGEMENT=true
# FEATURE_NFS_MANAGEMENT=true

# ============================================
# Harbor Registry (for CI/CD)
# ============================================
# HARBOR_URL=harbor.aglz.io:5000
# HARBOR_USERNAME=admin
# HARBOR_PASSWORD=SecurePass2025!
# HARBOR_PROJECT=dev
