# Cursor Pro pool — sem override OpenAI/Anthropic Base URL
# Uso: source antes de abrir Cursor IDE (auth cursor-pro)
unset OPENAI_API_BASE 2>/dev/null || true
unset OPENAI_BASE_URL 2>/dev/null || true
unset ANTHROPIC_BASE_URL 2>/dev/null || true
unset ANTHROPIC_API_KEY 2>/dev/null || true
export AGL_CURSOR_AUTH=cursor-pro
export LITELLM_GATEWAY_URL="${LITELLM_GATEWAY_URL:-http://100.125.249.8:4000}"
