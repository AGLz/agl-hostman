# OpenClaw — acesso directo aos providers (sem LiteLLM)
# Fonte no repo: config/openclaw/zshrc-openclaw-direct.env
# Colocar valores reais em ~/.openclaw/.env (600) ou exportar antes de `openclaw gateway`.

# --- Anthropic (Claude) — built-in API (sem proxy LiteLLM) ---
unset ANTHROPIC_BASE_URL 2>/dev/null || true
export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}"
export ANTHROPIC_AUTH_TOKEN="${ANTHROPIC_AUTH_TOKEN:-$ANTHROPIC_API_KEY}"

# --- OpenAI — built-in ---
export OPENAI_API_KEY="${OPENAI_API_KEY:-}"
export OPENAI_API_KEY_ALT="${OPENAI_API_KEY_ALT:-$OPENAI_API_KEY}"

# --- Google Gemini — built-in (GOOGLE_API_KEY ou GEMINI_API_KEY) ---
export GOOGLE_API_KEY="${GOOGLE_API_KEY:-}"
export GEMINI_API_KEY="${GEMINI_API_KEY:-$GOOGLE_API_KEY}"

# --- Z.AI (GLM) — primário AGL até novo aviso; docs: ZAI_API_KEY ---
export ZAI_API_KEY="${ZAI_API_KEY:-}"
export GLM_API_KEY="${GLM_API_KEY:-$ZAI_API_KEY}"
export GLM_AUTH="${GLM_AUTH:-$ZAI_API_KEY}"

# --- DeepSeek — built-in (OpenAI-compatible em /v1, NÃO /anthropic) ---
export DEEPSEEK_URL="${DEEPSEEK_URL:-https://api.deepseek.com/v1}"
export DEEPSEEK_API_KEY="${DEEPSEEK_API_KEY:-}"

# --- Moonshot (Kimi) — models.providers explícito no patch; chave OpenAI-compat ---
export MOONSHOT_API_KEY="${MOONSHOT_API_KEY:-}"
export KIMI_API_KEY="${KIMI_API_KEY:-$MOONSHOT_API_KEY}"
export KIMI_AUTH="${KIMI_AUTH:-$MOONSHOT_API_KEY}"

# --- Alibaba DashScope (Qwen, OpenAI-compat) ---
# Contas Singapore / consola intl: usar dashscope-intl (ver .zshrc DASHSCOPE_URL).
export DASHSCOPE_API_KEY="${DASHSCOPE_API_KEY:-}"
export DASHSCOPE_URL="${DASHSCOPE_URL:-https://dashscope-intl.aliyuncs.com/compatible-mode/v1}"
export ALIBABA_CLOUD_API_KEY="${ALIBABA_CLOUD_API_KEY:-$DASHSCOPE_API_KEY}"

# --- OpenRouter (opcional) ---
export OPENROUTER_API_KEY="${OPENROUTER_API_KEY:-}"

# --- Cerebras (LiteLLM / proxy — IDs: cerebras-llama-33, cerebras-gpt-oss-120b) ---
export CEREBRAS_API_KEY="${CEREBRAS_API_KEY:-}"

# --- OpenClaw CLI (openclaw models set) — qwen3.5-flash default ---
export AGL_OPENCLAW_PRIMARY_MODEL="${AGL_OPENCLAW_PRIMARY_MODEL:-qwen3.5-flash}"

# --- Ollama (opcional) — CT200: TS http://100.116.57.111:11434 | LAN 192.168.0.200:11434 ---
export OLLAMA_API_KEY="${OLLAMA_API_KEY:-}"
export OLLAMA_HOST="${OLLAMA_HOST:-http://127.0.0.1:11434}"

# Reason: não fazer unset de LITELLM_* aqui — o mesmo shell pode fazer `source zshrc-openclaw.env`
# seguido de `cclitellm` no .zshrc; apagar LITELLM_MASTER_KEY forçava o fallback sk-litellm-default
# e 401 no proxy. Modo direct continua a usar API Anthropic via ANTHROPIC_BASE_URL unset acima.
