# === OpenClaw + LiteLLM + Claude-Flow - Variáveis de Ambiente ===
# Incluir no ~/.zshrc: source /path/to/config/openclaw/zshrc-openclaw.env
# Última atualização: 2026-03-25 — IDs alinhados com config/litellm/config.yaml (GPT-5.4 mini, Gemini 3.1 preview, Qwen snapshot)

# Repo root (para cclitellm)
_CLAUDE_FLOW_REPO="${_CLAUDE_FLOW_REPO:-$(cd "$(dirname "${BASH_SOURCE[0]:-.}")/../.." 2>/dev/null && pwd)}"

# --- LiteLLM (definir PRIMEIRO — usado por ANTHROPIC_* no gateway) ---
export LITELLM_MASTER_KEY="${LITELLM_MASTER_KEY:-sk-litellm-default}"
export LITELLM_GATEWAY_URL="${LITELLM_GATEWAY_URL:-http://localhost:4000}"

# --- Anthropic (Claude Code → LiteLLM gateway) ---
# Use apiKeyHelper do .claude/settings.json — NÃO definir ANTHROPIC_AUTH_TOKEN (conflito)
# Devcontainer: LITELLM_GATEWAY_URL=100.94.221.87:4000 | Host: localhost:4000
export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-${LITELLM_GATEWAY_URL:-http://localhost:4000}}"
unset ANTHROPIC_AUTH_TOKEN
unset ANTHROPIC_API_KEY

# --- ZAI/GLM (oficial: ZAI_API_KEY; legado OpenClaw: GLM_AUTH) ---
export GLM_URL="${GLM_URL:-https://api.z.ai/api/anthropic}"
export ZAI_API_KEY="${ZAI_API_KEY:-}"
export GLM_AUTH="${GLM_AUTH:-$ZAI_API_KEY}"

# --- Moonshot/Kimi (oficial LiteLLM: MOONSHOT_API_KEY; legado: KIMI_AUTH) ---
export KIMI_URL="${KIMI_URL:-https://api.moonshot.ai/anthropic}"
export MOONSHOT_API_KEY="${MOONSHOT_API_KEY:-}"
export KIMI_AUTH="${KIMI_AUTH:-$MOONSHOT_API_KEY}"

# --- DeepSeek ---
export DEEPSEEK_URL="${DEEPSEEK_URL:-https://api.deepseek.com/anthropic}"
export DEEPSEEK_API_KEY="${DEEPSEEK_API_KEY:-}"
export DEEPSEEK_AUTH="${DEEPSEEK_AUTH:-$DEEPSEEK_API_KEY}"

# --- OpenAI ---
export OPENAI_URL="${OPENAI_URL:-https://api.openai.com/v1}"
export OPENAI_API_KEY="${OPENAI_API_KEY:-}"
export OPENAI_AUTH="${OPENAI_AUTH:-$OPENAI_API_KEY}"

# --- Google Gemini ---
export GEMINI_URL="${GEMINI_URL:-https://generativelanguage.googleapis.com/v1beta}"
export GEMINI_API_KEY="${GEMINI_API_KEY:-}"
export GEMINI_AUTH="${GEMINI_AUTH:-$GEMINI_API_KEY}"

# --- Referência: modelos no LiteLLM (qualificados para pedidos ao gateway :4000) ---
# openai/gpt-5.3-chat-latest e gpt-5.3-instant são aliases no proxy → backend API OpenAI gpt-5.4-mini
# gemini: código API Google = gemini-3.1-pro-preview; no gateway usar google/gemini-3.1-pro-preview
# Qwen Plus: DashScope (modo OpenAI-compat) = qwen3.5-plus-2026-02-15; no LiteLLM alias típico = qwen3.5-plus
export AGL_LITELLM_OPENAI_FAST="${AGL_LITELLM_OPENAI_FAST:-openai/gpt-5.3-chat-latest}"
export AGL_LITELLM_OPENAI_GPT="${AGL_LITELLM_OPENAI_GPT:-openai/gpt-5.4}"
export AGL_LITELLM_OPENAI_MINI="${AGL_LITELLM_OPENAI_MINI:-openai/gpt-5.4-mini}"
export AGL_LITELLM_GEMINI_PRO="${AGL_LITELLM_GEMINI_PRO:-google/gemini-3.1-pro-preview}"
export AGL_DASHSCOPE_QWEN35_PLUS="${AGL_DASHSCOPE_QWEN35_PLUS:-qwen3.5-plus-2026-02-15}"

# --- OpenRouter (oficial: OPENROUTER_API_KEY; legado: OPENROUTER_AUTH) ---
export OPENROUTER_URL="${OPENROUTER_URL:-https://openrouter.ai/api/v1}"
export OPENROUTER_API_KEY="${OPENROUTER_API_KEY:-}"
export OPENROUTER_AUTH="${OPENROUTER_AUTH:-$OPENROUTER_API_KEY}"

# --- cclitellm (Claude Code + LiteLLM) ---
# Uso: source config/openclaw/zshrc-openclaw.env && cclitellm
# Chave via apiKeyHelper (.claude/settings.json) — evita conflito token vs apiKeyHelper
cclitellm() {
  export LITELLM_GATEWAY_URL="${LITELLM_GATEWAY_URL:-http://localhost:4000}"
  export ANTHROPIC_BASE_URL="${LITELLM_GATEWAY_URL}"
  unset ANTHROPIC_AUTH_TOKEN
  unset ANTHROPIC_API_KEY
  echo "✓ Claude Code/Claude-Flow → LiteLLM ($LITELLM_GATEWAY_URL) [apiKeyHelper]"
}

# OpenClaw — verificação rápida (requer npm -g openclaw)
ochealth() {
  command -v openclaw >/dev/null 2>&1 || {
    echo "openclaw não encontrado (npm install -g openclaw)"
    return 1
  }
  echo "=== openclaw status ==="
  openclaw status 2>&1 | head -30
  echo ""
  echo "=== openclaw doctor (início) ==="
  openclaw doctor 2>&1 | head -25
}
