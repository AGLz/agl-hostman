# === OpenClaw + LiteLLM + Claude-Flow - Variáveis de Ambiente ===
# Incluir no ~/.zshrc: source /path/to/config/openclaw/zshrc-openclaw.env
# Última atualização: 2026-03-25 — IDs alinhados com config/litellm/config.yaml (GPT-5.4 mini, Gemini 3.1 preview, Qwen snapshot)

# Repo root (para ccll)
_CLAUDE_FLOW_REPO="${_CLAUDE_FLOW_REPO:-$(cd "$(dirname "${BASH_SOURCE[0]:-.}")/../.." 2>/dev/null && pwd)}"

# --- LiteLLM (definir PRIMEIRO — usado por ANTHROPIC_* no gateway) ---
# Reason: nunca usar sk-litellm-default como omissão — não está na DB do proxy → 401 token_not_found_in_db
if [[ -z "${LITELLM_MASTER_KEY:-}" && -r "${HOME:-}/.openclaw/litellm-master.secret.env" ]]; then
  # shellcheck source=/dev/null
  source "${HOME}/.openclaw/litellm-master.secret.env"
fi
export LITELLM_GATEWAY_URL="${LITELLM_GATEWAY_URL:-http://100.125.249.8:4000}"
if [[ -n "${LITELLM_MASTER_KEY:-}" ]]; then
  export LITELLM_MASTER_KEY
  export LITELLM_API_KEY="${LITELLM_API_KEY:-$LITELLM_MASTER_KEY}"
fi

# --- Anthropic (Claude Code → LiteLLM gateway) ---
# Use apiKeyHelper do .claude/settings.json — NÃO definir ANTHROPIC_AUTH_TOKEN (conflito)
# Gateway canónico: CT186 aglsrv1-litellm (100.125.249.8:4000)
export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-${LITELLM_GATEWAY_URL:-http://100.125.249.8:4000}}"
unset ANTHROPIC_AUTH_TOKEN
unset ANTHROPIC_API_KEY

# --- ZAI/GLM (oficial: ZAI_API_KEY; legado OpenClaw: GLM_AUTH) ---
export GLM_URL="${GLM_URL:-https://api.z.ai/api/anthropic}"
export ZAI_API_KEY="${ZAI_API_KEY:-}"
export GLM_AUTH="${GLM_AUTH:-$ZAI_API_KEY}"

# --- Moonshot/Kimi (oficial LiteLLM: MOONSHOT_API_KEY; legado: KIMI_AUTH) ---
export KIMI_URL="${KIMI_URL:-https://api.moonshot.ai/anthropic}"
export MOONSHOT_API_KEY="${MOONSHOT_API_KEY:-}"
export KIMI_AUTH="${KIMI_AUTH:-$MOONSHOT_API_KEY}"

# --- DeepSeek ---
export DEEPSEEK_URL="${DEEPSEEK_URL:-https://api.deepseek.com/anthropic}"
export DEEPSEEK_API_KEY="${DEEPSEEK_API_KEY:-}"
export DEEPSEEK_AUTH="${DEEPSEEK_AUTH:-$DEEPSEEK_API_KEY}"

# --- OpenAI ---
export OPENAI_URL="${OPENAI_URL:-https://api.openai.com/v1}"
export OPENAI_API_KEY="${OPENAI_API_KEY:-}"
export OPENAI_AUTH="${OPENAI_AUTH:-$OPENAI_API_KEY}"

# --- Google Gemini ---
export GEMINI_URL="${GEMINI_URL:-https://generativelanguage.googleapis.com/v1beta}"
export GEMINI_API_KEY="${GEMINI_API_KEY:-}"
export GEMINI_AUTH="${GEMINI_AUTH:-$GEMINI_API_KEY}"

# --- Referência: modelos no LiteLLM (qualificados para pedidos ao gateway :4000) ---
# openai/gpt-5.3-chat-latest e gpt-5.3-instant são aliases no proxy → backend API OpenAI gpt-5.4-mini
# gemini: código API Google = gemini-3.1-pro-preview; no gateway usar google/gemini-3.1-pro-preview
# Qwen Plus: DashScope (modo OpenAI-compat) = qwen3.5-plus-2026-02-15; no LiteLLM alias típico = qwen3.5-plus
export AGL_LITELLM_OPENAI_FAST="${AGL_LITELLM_OPENAI_FAST:-openai/gpt-5.3-chat-latest}"
export AGL_LITELLM_OPENAI_GPT="${AGL_LITELLM_OPENAI_GPT:-openai/gpt-5.4}"
export AGL_LITELLM_OPENAI_MINI="${AGL_LITELLM_OPENAI_MINI:-openai/gpt-5.4-mini}"
export AGL_LITELLM_GEMINI_PRO="${AGL_LITELLM_GEMINI_PRO:-google/gemini-3.1-pro-preview}"
export AGL_DASHSCOPE_QWEN35_PLUS="${AGL_DASHSCOPE_QWEN35_PLUS:-qwen3.5-plus-2026-02-15}"

# --- OpenClaw + Claude Code (gateway LiteLLM) — política 2026-06 ---
# Ollama GPU (sem limites) → Z.AI → OpenAI → Anthropic → free
export AGL_OPENCLAW_PRIMARY_MODEL="${AGL_OPENCLAW_PRIMARY_MODEL:-openai/agl-primary}"
export AGL_OPENCLAW_FALLBACK_MODELS="${AGL_OPENCLAW_FALLBACK_MODELS:-openai/zai-glm-5,openai/glm-5,openai/zai-coding-glm-4.7,openai/gpt-5.4-mini,openai/claude-haiku}"
# Pedidos ao proxy (:4000) — alias primário AGL no config.yaml (Ollama qwen3:4b GPU)
export AGL_LITELLM_MODEL_FAST="${AGL_LITELLM_MODEL_FAST:-agl-primary-zai-glm-flash}"
# Claude Code (ccll) — aliases agl-* no gateway (ver config/litellm/config.yaml)
export AGL_CC_MODEL_DEFAULT="${AGL_CC_MODEL_DEFAULT:-claude-sonnet-5}"
export AGL_CC_MODEL_SONNET="${AGL_CC_MODEL_SONNET:-claude-sonnet-5}"
export AGL_CC_MODEL_OPUS="${AGL_CC_MODEL_OPUS:-claude-opus-4-8}"
export AGL_CC_MODEL_HAIKU="${AGL_CC_MODEL_HAIKU:-claude-haiku-4-5-20251001}"
export AGL_LITELLM_MODEL_ZAI="${AGL_LITELLM_MODEL_ZAI:-zai-glm-5}"
export AGL_LITELLM_MODEL_ZAI_CODING="${AGL_LITELLM_MODEL_ZAI_CODING:-zai-coding-glm-4.7}"
# Referência: modelos Qwen disponíveis
export AGL_QWEN_DEFAULT="${AGL_QWEN_DEFAULT:-agl-primary}"
# Alias LiteLLM (backend DeepSeek); nunca enviar qwen3-coder-plus à API Alibaba
export AGL_QWEN_CODER="${AGL_QWEN_CODER:-qwen-coder}"
export AGL_QWEN_FLASH="${AGL_QWEN_FLASH:-qwen-flash-2025-07-28}"
export AGL_QWEN_CODER_FLASH="${AGL_QWEN_CODER_FLASH:-qwen3-coder-flash-2025-07-28}"
export AGL_QWEN_REASONING="${AGL_QWEN_REASONING:-qwq-plus-latest}"

# --- OpenRouter (oficial: OPENROUTER_API_KEY; legado: OPENROUTER_AUTH) ---
export OPENROUTER_URL="${OPENROUTER_URL:-https://openrouter.ai/api/v1}"
export OPENROUTER_API_KEY="${OPENROUTER_API_KEY:-}"
export OPENROUTER_AUTH="${OPENROUTER_AUTH:-$OPENROUTER_API_KEY}"

# --- ccll (Claude Code + LiteLLM) ---
# Uso: source config/openclaw/zshrc-openclaw.env && ccll
# Chave via apiKeyHelper (.claude/settings.json) — evita conflito token vs apiKeyHelper
ccll() {
  export CC_PROVIDER=litellm
  case "${LITELLM_GATEWAY_URL:-}" in
    *100.94.221.87*|*192.168.0.179*) export LITELLM_GATEWAY_URL="http://100.125.249.8:4000" ;;
  esac
  export LITELLM_GATEWAY_URL="${LITELLM_GATEWAY_URL:-http://100.125.249.8:4000}"
  export ANTHROPIC_BASE_URL="${LITELLM_GATEWAY_URL}"
  export ANTHROPIC_MODEL="${AGL_CC_MODEL_DEFAULT:-agl-primary}"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="${AGL_CC_MODEL_SONNET:-agl-primary}"
  export ANTHROPIC_DEFAULT_OPUS_MODEL="${AGL_CC_MODEL_OPUS:-agl-primary-strong}"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="${AGL_CC_MODEL_HAIKU:-agl-primary-zai-glm-flash}"
  export ANTHROPIC_SMALL_FAST_MODEL="${AGL_CC_MODEL_HAIKU:-agl-primary-zai-glm-flash}"
  if [[ -z "${LITELLM_MASTER_KEY:-}" && -r "${HOME:-}/.openclaw/litellm-master.secret.env" ]]; then
    # shellcheck source=/dev/null
    source "${HOME}/.openclaw/litellm-master.secret.env"
  fi
  unset ANTHROPIC_AUTH_TOKEN ANTHROPIC_API_KEY
  echo "✓ Claude Code/Claude-Flow → LiteLLM ($LITELLM_GATEWAY_URL) [${AGL_CC_MODEL_DEFAULT:-agl-primary-zai-glm-flash}]"
}

# OpenClaw — verificação rápida (requer npm -g openclaw)
ochealth() {
  command -v openclaw >/dev/null 2>&1 || {
    echo "openclaw não encontrado (npm install -g openclaw)"
    return 1
  }
  echo "=== openclaw status ==="
  openclaw status 2>&1 | head -30
  echo ""
  echo "=== openclaw doctor (início) ==="
  openclaw doctor 2>&1 | head -25
}
