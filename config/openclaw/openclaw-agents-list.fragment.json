{
  "agents": {
    "list": [
      {
        "id": "main",
        "default": true,
        "workspace": "~/.openclaw/workspace",
        "subagents": {
          "allowAgents": ["infra", "storage", "harbor", "net"]
        }
      },
      {
        "id": "infra",
        "workspace": "~/.openclaw/workspace-infra",
        "model": {
          "primary": "dashscope/qwen-coder",
          "fallbacks": [
            "dashscope/qwen3.5-flash",
            "dashscope/qwen-plus",
            "openrouter/z-ai/glm-4.5-air:free",
            "deepseek"
          ]
        },
        "groupChat": {
          "mentionPatterns": ["@infra", "\\binfra\\b"]
        }
      },
      {
        "id": "storage",
        "workspace": "~/.openclaw/workspace-storage",
        "model": {
          "primary": "dashscope/qwen-coder",
          "fallbacks": [
            "dashscope/qwen3.5-flash",
            "dashscope/qwen-plus",
            "deepseek",
            "gemini-lite"
          ]
        },
        "groupChat": {
          "mentionPatterns": ["@storage", "\\bstorage\\b", "\\bpool\\b", "\\bzfs\\b"]
        }
      },
      {
        "id": "harbor",
        "workspace": "~/.openclaw/workspace-harbor",
        "model": {
          "primary": "dashscope/qwen-coder",
          "fallbacks": ["dashscope/qwen3.5-flash", "dashscope/qwen-plus", "deepseek"]
        },
        "groupChat": {
          "mentionPatterns": ["@harbor", "\\bregistry\\b", "\\bharbor\\b"]
        }
      },
      {
        "id": "net",
        "workspace": "~/.openclaw/workspace-net",
        "model": {
          "primary": "dashscope/qwen-coder",
          "fallbacks": ["dashscope/qwen3.5-flash", "dashscope/qwen-plus", "deepseek", "gemini-lite"]
        },
        "groupChat": {
          "mentionPatterns": ["@net", "\\bwg\\b", "\\btailscale\\b"]
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "infra",
      "match": {
        "channel": "telegram",
        "peer": {
          "kind": "group",
          "id": "-100REPLACE_WITH_TELEGRAM_GROUP_ID"
        }
      }
    }
  ]
}
