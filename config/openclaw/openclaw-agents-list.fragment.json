{
  "agents": {
    "list": [
      {
        "id": "main",
        "default": true,
        "workspace": "~/.openclaw/workspace",
        "subagents": {
          "allowAgents": ["infra", "storage", "harbor", "net"]
        }
      },
      {
        "id": "infra",
        "workspace": "~/.openclaw/workspace-infra",
        "model": {
          "primary": "zai/glm-5",
          "fallbacks": [
            "deepseek/deepseek-chat",
            "openai/gpt-5.3-chat-latest",
            "anthropic/claude-sonnet-4-6"
          ]
        },
        "groupChat": {
          "mentionPatterns": ["@infra", "\\binfra\\b"]
        }
      },
      {
        "id": "storage",
        "workspace": "~/.openclaw/workspace-storage",
        "model": {
          "primary": "zai/glm-4.7-flash",
          "fallbacks": [
            "gemini-lite",
            "deepseek/deepseek-chat"
          ]
        },
        "groupChat": {
          "mentionPatterns": ["@storage", "\\bstorage\\b", "\\bpool\\b", "\\bzfs\\b"]
        }
      },
      {
        "id": "harbor",
        "workspace": "~/.openclaw/workspace-harbor",
        "model": {
          "primary": "deepseek/deepseek-chat",
          "fallbacks": ["zai/glm-5", "moonshot/kimi-k2.5"]
        },
        "groupChat": {
          "mentionPatterns": ["@harbor", "\\bregistry\\b", "\\bharbor\\b"]
        }
      },
      {
        "id": "net",
        "workspace": "~/.openclaw/workspace-net",
        "model": {
          "primary": "gemini-lite",
          "fallbacks": ["zai/glm-4.7-flash", "deepseek/deepseek-chat"]
        },
        "groupChat": {
          "mentionPatterns": ["@net", "\\bwg\\b", "\\btailscale\\b"]
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "infra",
      "match": {
        "channel": "telegram",
        "peer": {
          "kind": "group",
          "id": "-100REPLACE_WITH_TELEGRAM_GROUP_ID"
        }
      }
    }
  ]
}
