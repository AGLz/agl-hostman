# LiteLLM local (localhost:4000)
# Usar em: agldv03, fgsrv06, devcontainer com proxy na mesma máquina, ou workstation com Docker LiteLLM
# Source antes de zshrc-openclaw.env (deploy-openclaw-config.sh copia isto para ~/.openclaw/litellm-gateway.env)
export LITELLM_GATEWAY_URL="http://localhost:4000"
export ANTHROPIC_BASE_URL="http://localhost:4000"
