{
  "gateway": {
    "mode": "local"
  },
  "commands": {
    "bash": false,
    "restart": false,
    "config": false,
    "debug": false
  },
  "channels": {
    "defaults": {
      "heartbeat": {
        "showOk": false,
        "showAlerts": true,
        "useIndicator": true
      }
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    },
    "allowBundled": [
      "coding-agent",
      "gemini",
      "gh-issues",
      "github",
      "healthcheck",
      "node-connect",
      "openai-image-gen",
      "openai-whisper-api",
      "session-logs",
      "skill-creator",
      "tmux",
      "weather"
    ]
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "zai/glm-4.7-flash",
        "fallbacks": [
          "openrouter/deepseek/deepseek-chat",
          "openrouter/meta-llama/llama-3.3-70b-instruct:free",
          "openrouter/z-ai/glm-4.5-air:free",
          "zai/glm-5",
          "dashscope/qwen-plus"
        ]
      },
      "imageModel": {
        "primary": "zai/glm-4.7-flash",
        "fallbacks": [
          "openrouter/deepseek/deepseek-chat",
          "openrouter/meta-llama/llama-3.3-70b-instruct:free",
          "zai/glm-5"
        ]
      },
      "timeoutSeconds": 600,
      "maxConcurrent": 3,
      "models": {
        "zai/glm-5": { "alias": "glm" },
        "zai/glm-4.7": { "alias": "glm-4.7" },
        "zai/glm-4.7-flash": { "alias": "glm-flash" },
        "zai/glm-4.5-flash": { "alias": "glm-flash-45" },
        "moonshot/kimi-k2.5": { "alias": "kimi-k2" },
        "moonshot/kimi-k2-thinking": { "alias": "kimi-think" },
        "openrouter/deepseek/deepseek-chat": { "alias": "deepseek" },
        "openrouter/deepseek/deepseek-r1": { "alias": "r1" },
        "openai/gpt-4o": { "alias": "gpt-4o" },
        "openai/gpt-4o-mini": { "alias": "gpt-mini" },
        "openai/gpt-4.1": { "alias": "gpt-4.1" },
        "google/gemini-2.5-flash": { "alias": "gemini-flash" },
        "google/gemini-2.5-pro": { "alias": "gemini-pro" },
        "google/gemini-2.5-flash-lite": { "alias": "gemini-lite" },
        "google/gemini-3.1-pro-preview": { "alias": "gemini" },
        "dashscope/qwen-plus": { "alias": "qwen-plus" },
        "openrouter/z-ai/glm-4.5-air:free": { "alias": "or-glm-air-free" },
        "openrouter/meta-llama/llama-3.3-70b-instruct:free": { "alias": "or-llama-free" }
      }
    }
  }
}
