{
  "gateway": {
    "mode": "local"
  },
  "commands": {
    "bash": false,
    "restart": false,
    "config": false,
    "debug": false
  },
  "channels": {
    "defaults": {
      "heartbeat": {
        "showOk": false,
        "showAlerts": true,
        "useIndicator": true
      }
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    },
    "allowBundled": [
      "coding-agent",
      "gemini",
      "gh-issues",
      "github",
      "healthcheck",
      "node-connect",
      "openai-image-gen",
      "openai-whisper-api",
      "session-logs",
      "skill-creator",
      "tmux",
      "weather"
    ]
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "dashscope/qwen3.5-flash",
        "fallbacks": [
          "dashscope/qwen-coder",
          "openrouter/z-ai/glm-4.5-air:free",
          "openrouter/deepseek/deepseek-chat",
          "openrouter/meta-llama/llama-3.3-70b-instruct:free"
        ]
      },
      "imageModel": {
        "primary": "dashscope/qwen3.5-flash",
        "fallbacks": [
          "openrouter/deepseek/deepseek-chat",
          "openrouter/meta-llama/llama-3.3-70b-instruct:free"
        ]
      },
      "timeoutSeconds": 600,
      "maxConcurrent": 3,
      "models": {
        "dashscope/qwen3.5-flash": { "alias": "qwen3.5-flash" },
        "dashscope/qwen-plus": { "alias": "qwen-plus" },
        "dashscope/qwen-coder": { "alias": "qwen-coder" },
        "dashscope/qwen-flash": { "alias": "qwen-flash" },
        "dashscope/qwen3-coder-flash": { "alias": "qwen3-coder-flash" },
        "dashscope/qwq-plus": { "alias": "qwq-plus" },
        "openrouter/deepseek/deepseek-chat": { "alias": "deepseek" },
        "openrouter/deepseek/deepseek-r1": { "alias": "r1" },
        "openai/gpt-4o": { "alias": "gpt-4o" },
        "openai/gpt-4o-mini": { "alias": "gpt-mini" },
        "openai/gpt-4.1": { "alias": "gpt-4.1" },
        "google/gemini-2.5-flash": { "alias": "gemini-flash" },
        "google/gemini-2.5-pro": { "alias": "gemini-pro" },
        "google/gemini-2.5-flash-lite": { "alias": "gemini-lite" },
        "google/gemini-3.1-pro-preview": { "alias": "gemini" },
        "openrouter/z-ai/glm-4.5-air:free": { "alias": "or-glm-air-free" },
        "openrouter/meta-llama/llama-3.3-70b-instruct:free": { "alias": "or-llama-free" },
        "openai/ollama-nemotron-3-nano-4b": { "alias": "nemotron-local" }
      }
    }
  }
}
