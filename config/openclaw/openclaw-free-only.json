{
  "gateway": {
    "mode": "local"
  },
  "commands": {
    "bash": false,
    "restart": false,
    "config": false,
    "debug": false
  },
  "channels": {
    "defaults": {
      "heartbeat": {
        "showOk": false,
        "showAlerts": true,
        "useIndicator": true
      }
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    },
    "allowBundled": [
      "coding-agent",
      "gemini",
      "gh-issues",
      "github",
      "healthcheck",
      "node-connect",
      "openai-image-gen",
      "openai-whisper-api",
      "session-logs",
      "skill-creator",
      "tmux",
      "weather"
    ]
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "qwen/qwen3.5-flash",
        "fallbacks": [
          "qwen/qwen-flash",
          "qwen/qwen-coder",
          "qwen/qwen-turbo",
          "openrouter/z-ai/glm-4.5-air:free",
          "openrouter/meta-llama/llama-3.3-70b-instruct:free",
          "openrouter/google/gemma-3-4b-it:free"
        ]
      },
      "imageModel": {
        "primary": "qwen/qwen3.5-flash",
        "fallbacks": [
          "openrouter/google/gemma-3-4b-it:free"
        ]
      },
      "timeoutSeconds": 600,
      "maxConcurrent": 3,
      "models": {
        "qwen/qwen3.5-flash": { "alias": "qwen3.5-flash", "free": true },
        "qwen/qwen-flash": { "alias": "qwen-flash", "free": true },
        "qwen/qwen-coder": { "alias": "qwen-coder", "free": true },
        "qwen/qwen3-coder-flash": { "alias": "qwen3-coder-flash", "free": true },
        "qwen/qwen-turbo": { "alias": "qwen-turbo", "free": true },
        "qwen/qwq-plus": { "alias": "qwq-plus", "free": true },
        "openrouter/z-ai/glm-4.5-air:free": { "alias": "or-glm-air-free", "free": true },
        "openrouter/meta-llama/llama-3.3-70b-instruct:free": { "alias": "or-llama-free", "free": true },
        "openrouter/google/gemma-3-4b-it:free": { "alias": "gemma-free", "free": true },
        "openrouter/google/gemma-3-12b-it:free": { "alias": "gemma-12b-free", "free": true },
        "openrouter/google/gemma-3-27b-it:free": { "alias": "gemma-27b-free", "free": true },
        "openrouter/mistralai/mistral-small-3.1-24b-instruct:free": { "alias": "mistral-free", "free": true },
        "openrouter/nousresearch/hermes-3-llama-3.1-405b:free": { "alias": "hermes-free", "free": true },
        "openrouter/openrouter/free": { "alias": "or-router-free", "free": true }
      }
    }
  }
}
