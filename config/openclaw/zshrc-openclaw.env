# === OpenClaw + LiteLLM + Claude-Flow - Variáveis de Ambiente ===
# Incluir no ~/.zshrc: source /path/to/config/openclaw/zshrc-openclaw.env
# Última atualização: 2026-03

# --- LiteLLM (definir PRIMEIRO — usado por ANTHROPIC_* no gateway) ---
export LITELLM_MASTER_KEY="${LITELLM_MASTER_KEY:-sk-litellm-default}"
export LITELLM_GATEWAY_URL="${LITELLM_GATEWAY_URL:-http://localhost:4000}"

# --- Anthropic (Claude Code → LiteLLM gateway) ---
# CRÍTICO: SEMPRE use LITELLM_MASTER_KEY (sk-) — NUNCA ZAI_API_KEY (896f...) — LiteLLM rejeita 401
export ANTHROPIC_BASE_URL="${LITELLM_GATEWAY_URL}"
export ANTHROPIC_API_KEY="${LITELLM_MASTER_KEY}"
export ANTHROPIC_AUTH_TOKEN="${LITELLM_MASTER_KEY}"

# --- ZAI/GLM (OpenClaw usa GLM_AUTH; LiteLLM usa ZAI_API_KEY no SERVIDOR) ---
export GLM_URL="${GLM_URL:-https://api.z.ai/api/anthropic}"
export GLM_AUTH="${GLM_AUTH:-}"
export ZAI_API_KEY="${ZAI_API_KEY:-$GLM_AUTH}"

# --- Moonshot/Kimi (OpenClaw: KIMI_*; LiteLLM: MOONSHOT_*) ---
export KIMI_URL="${KIMI_URL:-https://api.moonshot.ai/anthropic}"
export KIMI_AUTH="${KIMI_AUTH:-}"
export MOONSHOT_API_KEY="${MOONSHOT_API_KEY:-$KIMI_AUTH}"

# --- DeepSeek ---
export DEEPSEEK_URL="${DEEPSEEK_URL:-https://api.deepseek.com/anthropic}"
export DEEPSEEK_AUTH="${DEEPSEEK_AUTH:-}"
export DEEPSEEK_API_KEY="${DEEPSEEK_API_KEY:-$DEEPSEEK_AUTH}"

# --- OpenAI ---
export OPENAI_URL="${OPENAI_URL:-https://api.openai.com/v1}"
export OPENAI_AUTH="${OPENAI_AUTH:-}"
export OPENAI_API_KEY="${OPENAI_API_KEY:-$OPENAI_AUTH}"

# --- Google Gemini ---
export GEMINI_URL="${GEMINI_URL:-https://generativelanguage.googleapis.com/v1beta}"
export GEMINI_AUTH="${GEMINI_AUTH:-}"
export GEMINI_API_KEY="${GEMINI_API_KEY:-$GEMINI_AUTH}"

# --- OpenRouter ---
export OPENROUTER_API_KEY="${OPENROUTER_API_KEY:-}"
