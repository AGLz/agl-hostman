# OpenClaw — env canónico (repo: config/openclaw/zshrc-openclaw.env)
# Por omissão: acesso directo aos providers. Para LiteLLM:
#   export OPENCLAW_ENV_MODE=litellm
# antes de fazer source (ou no systemd Environment=).
#
# zsh: ${0:A:h}; bash: BASH_SOURCE; fallback: OPENCLAW_ENV_ROOT

if [[ -n "${ZSH_VERSION:-}" ]]; then
  _oc_env_dir="${0:A:h}"
elif [[ -n "${BASH_SOURCE[0]:-}" ]]; then
  _oc_env_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
else
  _oc_env_dir="${OPENCLAW_ENV_ROOT:-.}"
fi
if [[ "${OPENCLAW_ENV_MODE:-}" == "litellm" ]]; then
  [[ -r "${_oc_env_dir}/zshrc-openclaw-litellm.env" ]] && source "${_oc_env_dir}/zshrc-openclaw-litellm.env"
else
  [[ -r "${_oc_env_dir}/zshrc-openclaw-direct.env" ]] && source "${_oc_env_dir}/zshrc-openclaw-direct.env"
fi
unset _oc_env_dir
