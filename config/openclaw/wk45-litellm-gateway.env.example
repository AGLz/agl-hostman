# aglwk45 (Windows / sem LiteLLM local): copiar para ~/.openclaw/litellm-gateway.env
# e colar o valor REAL de LITELLM_MASTER_KEY (mesmo que /opt/litellm/.env no agldv03).
# O ficheiro deve ser sourced ANTES de zshrc-openclaw.env no .bashrc (ver AGLWK45-SETUP.md).
#
# Reason: sk-litellm-default no repo não coincide com a chave de produção → 401 token_not_found_in_db
export LITELLM_GATEWAY_URL="http://100.94.221.87:4000"
export ANTHROPIC_BASE_URL="http://100.94.221.87:4000"
export LITELLM_MASTER_KEY="COPIAR_VALOR_DE_opt_litellm_env_no_agldv03"
