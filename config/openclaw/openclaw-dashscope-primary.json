{
  "gateway": {
    "mode": "local"
  },
  "commands": {
    "bash": false,
    "restart": false,
    "config": false,
    "debug": false
  },
  "channels": {
    "defaults": {
      "heartbeat": {
        "showOk": false,
        "showAlerts": true,
        "useIndicator": true
      }
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    },
    "allowBundled": [
      "coding-agent",
      "gemini",
      "gh-issues",
      "github",
      "healthcheck",
      "node-connect",
      "openai-image-gen",
      "openai-whisper-api",
      "session-logs",
      "skill-creator",
      "tmux",
      "weather"
    ]
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/qwen3.5-flash",
        "fallbacks": [
          "openai/qwen-coder",
          "openai/qwen3.5-flash",
          "openai/qwen-flash",
          "openai/qwen-turbo"
        ]
      },
      "imageModel": {
        "primary": "openai/qwen3.5-flash",
        "fallbacks": [
          "openai/qwen-turbo"
        ]
      },
      "timeoutSeconds": 600,
      "maxConcurrent": 3
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "openai": {
        "baseUrl": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
        "api": "openai-completions",
        "apiKey": "${DASHSCOPE_API_KEY}",
        "models": [
          {
            "id": "qwen3.5-flash",
            "name": "Qwen3.5 Flash (DEFAULT)",
            "reasoning": false,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 1e-07,
              "output": 5e-07,
              "cacheRead": 2e-08,
              "cacheWrite": 5e-08
            },
            "contextWindow": 1048576,
            "maxTokens": 65536
          },
          {
            "id": "qwen-plus",
            "name": "Qwen Plus",
            "reasoning": false,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 2.6e-07,
              "output": 1.56e-06,
              "cacheRead": 5e-08,
              "cacheWrite": 1e-07
            },
            "contextWindow": 1048576,
            "maxTokens": 65536
          },
          {
            "id": "qwen-coder",
            "name": "Qwen Coder (DEV SKILLS)",
            "reasoning": false,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 6.5e-07,
              "output": 3.25e-06,
              "cacheRead": 1.3e-07,
              "cacheWrite": 3.3e-07
            },
            "contextWindow": 1048576,
            "maxTokens": 65536
          },
          {
            "id": "qwen3-coder-flash",
            "name": "Qwen3 Coder Flash (DEV FAST)",
            "reasoning": false,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 3.5e-07,
              "output": 1.75e-06,
              "cacheRead": 7e-08,
              "cacheWrite": 1.8e-07
            },
            "contextWindow": 1048576,
            "maxTokens": 65536
          },
          {
            "id": "qwen-flash",
            "name": "Qwen Flash (ULTRA CHEAP)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 7e-08,
              "output": 3.5e-07,
              "cacheRead": 1e-08,
              "cacheWrite": 4e-08
            },
            "contextWindow": 1048576,
            "maxTokens": 65536
          },
          {
            "id": "qwq-plus",
            "name": "QwQ Plus (REASONING)",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 2e-07,
              "output": 1e-06,
              "cacheRead": 4e-08,
              "cacheWrite": 1e-07
            },
            "contextWindow": 131072,
            "maxTokens": 65536
          },
          {
            "id": "qwen-turbo",
            "name": "Qwen Turbo (FREE)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      }
    }
  }
}