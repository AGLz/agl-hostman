# Cursor My Machines worker — User API Key (Pro+ / Pro / Ultra / Teams)
# Copiar para /etc/cursor/worker-pool.env (chmod 600, root:root)
#
# Criar em: Dashboard → Cloud Agents → User API Keys → Create
# NÃO usar chaves auto-geradas cursor-agent-worker-ext-* (são por sessão IDE).
#
# Uso:
#   CURSOR_API_KEY='key_...' sudo bash scripts/cursor/sync-cursor-worker-pool-env.sh
#   sudo bash scripts/cursor/enable-cursor-worker.sh
#   bash scripts/cursor/propagate-cursor-worker-pool.sh --host agldv-all

CURSOR_API_KEY=
