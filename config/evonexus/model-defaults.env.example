# Defaults EvoNexus / LiteLLM — política AGL 2026-06
# Ollama GPU (agl-primary) → Z.AI → OpenAI → Anthropic → outros
# Copiar linhas relevantes para /workspace/config/.env no **CT548** (fgsrv7 evonexus; ex.242)

# Terminal Claude (API Anthropic → LiteLLM)
ANTHROPIC_MODEL=agl-primary
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-7
EVONEXUS_ANTHROPIC_MODEL=agl-primary

# Provider litellm/openclaude no scheduler (OpenAI-compat)
OPENAI_MODEL=agl-primary
OPENAI_FALLBACK_MODEL=zai-glm-5
ZAI_MODEL=glm-5
ZAI_CODING_MODEL=zai-coding-glm-4.7

# Contexto longo / burst sem limites de tokens — preferir Ollama local
EVONEXUS_LONG_CONTEXT_MODEL=agl-primary

# Desactivar uso acidental (opcional: remover key do .env)
# DASHSCOPE_API_KEY=
