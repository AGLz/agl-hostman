[Unit]
Description=makemoney01 crm-dentista demo (PHP built-in)
After=network.target

[Service]
Type=simple
WorkingDirectory=/mnt/overpower/apps/dev/agl/crm-dentista/src/public
ExecStart=/usr/bin/php -S 127.0.0.1:8103 -t /mnt/overpower/apps/dev/agl/crm-dentista/src/public
Restart=on-failure
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
