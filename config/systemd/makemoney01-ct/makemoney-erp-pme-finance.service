[Unit]
Description=makemoney01 erp-pme-finance demo (PHP built-in)
After=network.target

[Service]
Type=simple
WorkingDirectory=/mnt/overpower/apps/dev/agl/erp-pme-finance/src/public
ExecStart=/usr/bin/php -S 127.0.0.1:8107 -t /mnt/overpower/apps/dev/agl/erp-pme-finance/src/public
Restart=on-failure
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
