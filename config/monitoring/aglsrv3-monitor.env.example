# Copiar para /etc/agl-hostman/monitor.env (agldv03) ou config/monitoring/aglsrv3-monitor.env (local, gitignored)
# chmod 600 — nunca commitar tokens.

# Telegram (opcional — sem token só regista em /var/log/hostman/aglsrv3-alerts.log)
AGL_ALERT_TELEGRAM_BOT_TOKEN=
AGL_ALERT_TELEGRAM_CHAT_ID=1272190248

# Prefixo nas mensagens
AGL_ALERT_PREFIX="[AGLSRV3]"
