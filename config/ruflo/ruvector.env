# RuVector - Memória vetorial para Ruflo/Claude-Flow
# Deploy: scripts/ruflo/setup-ruvector.sh
# Ref: https://github.com/ruvnet/ruflo

# === PostgreSQL (opcional - integração Archon) ===
# Archon usa Supabase; para RuVector local use SQLite (default)
# RUVECTOR_DATABASE_URL=postgresql://user:pass@100.80.30.59:5432/archon_db

# === SQLite (default - sem dependências) ===
RUVECTOR_STORAGE_PATH="${RUVECTOR_STORAGE_PATH:-$HOME/.ruflo/ruvector}"
RUVECTOR_DIMENSIONS=1536
RUVECTOR_INDEX_TYPE=hnsw

# === Benchmark ===
RUVECTOR_BENCHMARK_ITERATIONS=1000
