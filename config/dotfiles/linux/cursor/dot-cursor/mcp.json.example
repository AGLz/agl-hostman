{
  "mcpServers": {
    "archon": {
      "url": "http://100.80.30.59:8052/mcp"
    },
    "dokploy-mcp": {
      "command": "npx",
      "args": ["-y", "@ahdev/dokploy-mcp"],
      "env": {
        "DOKPLOY_URL": "https://dok.aglz.io/api",
        "DOKPLOY_API_KEY": "${DOKPLOY_API_KEY}"
      }
    },
    "composio": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://connect.composio.dev/mcp",
        "8787",
        "--header",
        "x-api-key:${COMPOSIO_API_KEY}"
      ],
      "env": {
        "COMPOSIO_API_KEY": "${COMPOSIO_API_KEY}"
      },
      "description": "Composio Connect — usar mcp-remote + túnel SSH em Remote SSH (ver scripts/cursor/composio-mcp-oauth-remote.sh)"
    }
  }
}
