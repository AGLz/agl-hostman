# Ollama Stack Environment Variables
# Copy to .env and customize

# ============================================================================
# Security
# ============================================================================

# Open WebUI - Secret key for session management
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=changeme-please-use-random-key-here

# LiteLLM - Master API key for admin access
# Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-1234-change-this-key

# LiteLLM - Salt key for hashing
# Generate with: openssl rand -hex 32
LITELLM_SALT_KEY=sk-salt-1234-change-this

# ============================================================================
# Database
# ============================================================================

# LiteLLM database path (SQLite)
DATABASE_URL=sqlite:////app/data/litellm.db

# ============================================================================
# Ollama Configuration
# ============================================================================

# Maximum models to keep loaded in memory
OLLAMA_MAX_LOADED_MODELS=3

# Number of parallel requests to handle
OLLAMA_NUM_PARALLEL=4

# GPU memory fraction to use (0.0 to 1.0)
OLLAMA_GPU_MEMORY_FRACTION=0.9

# Keep models alive for this duration
OLLAMA_KEEP_ALIVE=5m

# ============================================================================
# External API Keys (Optional)
# ============================================================================

# OpenAI API key (if using GPT models)
# OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API key (if using Claude models)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Cohere API key (if using Cohere models)
# COHERE_API_KEY=your-cohere-key-here

# ============================================================================
# Feature Flags
# ============================================================================

# Enable RAG web search in Open WebUI
ENABLE_RAG_WEB_SEARCH=true

# Enable image generation (requires compatible model)
ENABLE_IMAGE_GENERATION=false

# Enable community sharing
ENABLE_COMMUNITY_SHARING=false

# ============================================================================
# Performance Tuning
# ============================================================================

# Open WebUI worker processes
WEBUI_WORKERS=4

# LiteLLM worker processes
LITELLM_NUM_WORKERS=4

# Request timeout (seconds)
LITELLM_REQUEST_TIMEOUT=600

# ============================================================================
# Logging
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# LiteLLM logging
LITELLM_LOG=INFO

# ============================================================================
# Network Configuration
# ============================================================================

# Open WebUI URL
WEBUI_URL=http://10.6.0.17:3000

# Ollama host
OLLAMA_HOST=0.0.0.0:11434

# Ollama base URL for other services
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ============================================================================
# Notes
# ============================================================================
#
# 1. Generate secure keys:
#    openssl rand -hex 32
#
# 2. Never commit .env file with real keys to git
#
# 3. Restart containers after changing environment:
#    docker compose down && docker compose up -d
#
# 4. View current environment in running container:
#    docker exec <container> env
