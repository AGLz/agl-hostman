# LiteLLM Proxy - Variáveis de Ambiente
# Copiar para .env e preencher as chaves
# Ref: docs/CLAUDE-FLOW-LITELLM.md

# === Obrigatório ===
LITELLM_MASTER_KEY=sk-your-secure-master-key

# === Providers (pelo menos um para funcionar) ===

# Anthropic Claude (conta PRO - Opus 4.6, Sonnet 4.6, Haiku 4.5)
ANTHROPIC_API_KEY=

# ZAI/GLM (alias: GLM_AUTH no OpenClaw)
ZAI_API_KEY=

# Moonshot/Kimi (alias: KIMI_AUTH no OpenClaw)
MOONSHOT_API_KEY=

# DeepSeek (alias: DEEPSEEK_AUTH no OpenClaw)
DEEPSEEK_API_KEY=

# OpenAI (alias: OPENAI_AUTH no OpenClaw)
OPENAI_API_KEY=

# Google Gemini (alias: GEMINI_AUTH no OpenClaw)
GEMINI_API_KEY=

# OpenRouter (fallbacks gratuitos/alternativos)
OPENROUTER_API_KEY=

# === Compatibilidade com OpenClaw ===
# Se já tem GLM_AUTH, KIMI_AUTH etc no ~/.zshrc:
# export ZAI_API_KEY=$GLM_AUTH
# export MOONSHOT_API_KEY=$KIMI_AUTH
# export DEEPSEEK_API_KEY=$DEEPSEEK_AUTH

# === Notas (2026-02) ===
# - ANTHROPIC_API_KEY: conta PRO - Opus 4.6, Sonnet 4.6, Haiku 4.5
# - kimi-k2.5: modelo mais recente Moonshot (256k); use kimi-128k como fallback
# - gpt-5.2: requer conta OpenAI; gpt-4o como fallback se indisponível
# - glm-5: via OpenRouter; zai/glm-4.7 via API direta
