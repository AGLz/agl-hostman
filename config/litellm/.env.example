# Copiar para /opt/litellm/.env e preencher (nunca commitar o .env real).
# Reason: LITELLM_MASTER_KEY é opcional no LiteLLM; sem ela o proxy pode aceitar pedidos sem Bearer (evitar em produção exposta).

LITELLM_MASTER_KEY=

# Chaves dos fornecedores (exemplos; ver vault da equipa)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ZAI_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Google Vertex Express (aglznet) — API key AQ.* em https://console.cloud.google.com/apis/credentials
# SA típica: vertex-express@aglznet.iam.gserviceaccount.com
# LiteLLM: gemini/ + api_base .../v1/publishers/google (config.yaml); não usar vertex_ai/ (ADC).
# Repor em CT186: /opt/agl-litellm/.env  |  local: config/litellm/.env
GEMINI_API_KEY=
VERTEXAI_PROJECT=aglznet
VERTEXAI_LOCATION=global

GROQ_API_KEY=
GROQ_API_KEY2=
MOONSHOT_API_KEY=
REDIS_PASSWORD=
