# LiteLLM Proxy - Variáveis de Ambiente
# Copiar para .env e preencher as chaves
# Ref: docs/CLAUDE-FLOW-LITELLM.md

# === Obrigatório ===
LITELLM_MASTER_KEY=sk-your-secure-master-key

# === Providers (pelo menos um para funcionar) ===

# Cerebras — config.yaml: cerebras-llama-33, cerebras-gpt-oss-120b (export no ~/.zshrc ou .env do proxy)
# Ref: https://docs.litellm.ai/docs/providers/cerebras
CEREBRAS_API_KEY=

# Anthropic Claude (conta PRO - Opus 4.6, Sonnet 4.6, Haiku 4.5)
ANTHROPIC_API_KEY=

# ZAI/GLM (alias: GLM_AUTH no OpenClaw)
ZAI_API_KEY=

# Moonshot/Kimi (alias: KIMI_AUTH no OpenClaw)
MOONSHOT_API_KEY=

# DeepSeek (alias: DEEPSEEK_AUTH no OpenClaw)
DEEPSEEK_API_KEY=

# OpenAI (alias: OPENAI_AUTH no OpenClaw)
OPENAI_API_KEY=

# Google Gemini (alias: GEMINI_AUTH no OpenClaw)
GEMINI_API_KEY=

# Alibaba DashScope / Qwen direto no LiteLLM (alias no direct: ALIBABA_CLOUD_API_KEY)
DASHSCOPE_API_KEY=

# OpenRouter (modelos :free no LiteLLM; aliases no shell: OPENROUTER_AUTH)
# export OPENROUTER_API_KEY="${OPENROUTER_AUTH:-}"
OPENROUTER_API_KEY=

# Redis (cache de respostas LiteLLM)
# agldv03: CT137 em LAN (192.168.0.137) — ver cache_params em config.yaml
# fgsrv06: serviço litellm-redis no docker-compose-fgsrv06.yml (sem password no YAML gerado)
REDIS_PASSWORD=

# Groq — config.yaml / config-remote.yaml: groq-llama-33, groq-gpt-oss-120b, *-k2 → GROQ_API_KEY2
# https://console.groq.com/keys — validar: ./scripts/litellm/validate-groq-keys.sh
GROQ_API_KEY=
# Segunda chave (rotação / outra conta); opcional — mesmo script valida as duas
GROQ_API_KEY2=

# === Compatibilidade (preferir nomes oficiais acima) ===
# Legado OpenClaw / scripts antigos podem usar GLM_AUTH, KIMI_AUTH, OPENROUTER_AUTH:
# export GLM_AUTH="$ZAI_API_KEY"
# export KIMI_AUTH="$MOONSHOT_API_KEY"
# export OPENROUTER_AUTH="$OPENROUTER_API_KEY"

# === Notas (2026-03) ===
# - ANTHROPIC_API_KEY: Opus/Sonnet 4.6, Haiku 4.5 (IDs: docs.anthropic.com)
# - OPENAI_API_KEY: default alias `gpt` → gpt-5.4; Instant/Composer proxy → gpt-5.3-chat-latest
# - GEMINI_API_KEY: gemini-3.1-pro-preview (Gemini 3); gemini-2.0-flash deprecado
# - DASHSCOPE_API_KEY: Qwen3.5-* (config.yaml / config-remote.yaml)
# - kimi-k2.5: Moonshot (256k); glm-5 via Z.AI (config.yaml)
#
# Ollama (CT200) — só se LiteLLM/OpenClaw apontar para Ollama local/remoto
# OLLAMA_HOST=100.116.57.111:11434
