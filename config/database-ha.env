# =============================================================================
# MySQL High Availability Environment Configuration
# AGL Hostman - Database HA Environment Variables
# =============================================================================
#
# IMPORTANT: Copy this file to .env and update with actual values
# NEVER commit .env with actual credentials to version control
#
# Architecture:
#   Application (Laravel)
#       ↓
#   ProxySQL (Read/Write Splitting)
#       ↓
#   MySQL Master (Write) + MySQL Slaves (Read)
#
# =============================================================================

# =============================================================================
# MySQL Connection Settings
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=proxysql
DB_PORT=6032

# Direct connections (bypass ProxySQL for failover)
DB_MASTER_HOST=mysql-master
DB_MASTER_PORT=3306
DB_SLAVE1_HOST=mysql-slave-1
DB_SLAVE2_HOST=mysql-slave-2
DB_SLAVE_PORT=3306

# ProxySQL Configuration
DB_WRITE_HOST=proxysql
DB_WRITE_PORT=6032
DB_READ_HOST=proxysql
DB_READ_PORT=6033

# Database Credentials
DB_DATABASE=agl_hostman
DB_USERNAME=agl_user
DB_PASSWORD=changeme_secure_password_here

# Root Password (for backups, monitoring, failover)
MYSQL_ROOT_PASSWORD=changeme_root_password_here

# =============================================================================
# Replication Configuration
# =============================================================================
MYSQL_REPLICATION_USER=replicator
MYSQL_REPLICATION_PASSWORD=changeme_replication_password

# Replication Health
MYSQL_REPLICATION_CHECK_INTERVAL=10
MYSQL_MAX_REPLICATION_LAG=30
MYSQL_SEMI_SYNC_TIMEOUT=1000

# =============================================================================
# ProxySQL Configuration
# =============================================================================
PROXYSQL_ADMIN_PORT=6080
PROXYSQL_ADMIN_USER=admin
PROXYSQL_ADMIN_PASSWORD=admin
PROXYSQL_MONITOR_USER=root
PROXYSQL_MONITOR_PASSWORD=${MYSQL_ROOT_PASSWORD}

# ProxySQL Connection Pooling
PROXYSQL_MAX_CONNECTIONS=1000
PROXYSQL_MIN_CONNECTIONS=10
PROXYSQL_CONNECTION_TIMEOUT=300
PROXYSQL_IDLE_TIMEOUT=600

# =============================================================================
# Connection Pooling (Laravel)
# =============================================================================
DB_POOL_MIN=10
DB_POOL_MAX=100
DB_POOL_TIMEOUT=5
DB_POOL_IDLE_TIMEOUT=60
DB_STICKY=true

# =============================================================================
# Backup Configuration
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_TYPE=full
BACKUP_RETENTION_DAYS=7
BACKUP_ROOT=/srv/backups/mysql
BACKUP_COMPRESS=true

# Incremental Backup Schedule
BACKUP_INCREMENTAL_SCHEDULE="0 6,12,18 * * *"
BACKUP_INCREMENTAL_RETENTION_DAYS=3

# =============================================================================
# S3 Backup Configuration
# =============================================================================
S3_UPLOAD=false
S3_BUCKET=my-backups
S3_PREFIX=mysql-backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# =============================================================================
# Health Check Configuration
# =============================================================================
MYSQL_HEALTH_CHECK_ENABLED=true
MYSQL_HEALTH_CHECK_INTERVAL=30
MYSQL_HEALTH_CHECK_TIMEOUT=10

# Failover Configuration
MYSQL_FAILOVER_ENABLED=true
MYSQL_FAILOVER_CHECK_INTERVAL=10
MYSQL_FAILOVER_TIMEOUT=60
MYSQL_FAILOVER_AUTO_PROMOTE=true

# =============================================================================
# Monitoring Configuration
# =============================================================================
MYSQL_EXPORTER_ENABLED=true
MYSQL_EXPORTER_PORT=9104
MYSQL_SLOW_QUERY_THRESHOLD=2
MYSQL_QUERY_LOG_SIZE_LIMIT=1073741824

# Prometheus Exporter
MYSQL_EXPORTER_USER=exporter
MYSQL_EXPORTER_PASSWORD=changeme_exporter_password
MYSQL_EXPORTER_AUTO_DISCOVER=true

# =============================================================================
# Performance Tuning
# =============================================================================
MYSQL_MAX_CONNECTIONS=1000
MYSQL_INNODB_BUFFER_POOL_SIZE=4G
MYSQL_INNODB_LOG_FILE_SIZE=512M
MYSQL_INNODB_IO_CAPACITY=2000
MYSQL_QUERY_CACHE_SIZE=256M

# =============================================================================
# Failover & Alerting
# =============================================================================
# Alert Settings
ALERT_EMAIL=alerts@agl.local
ALERT_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK=${ALERT_WEBHOOK}

# PagerDuty Integration
PAGERDUTY_ENABLED=false
PAGERDUTY_API_KEY=
PAGERDUTY_SERVICE_KEY=

# =============================================================================
# Security Settings
# =============================================================================
# SSL/TLS Configuration
MYSQL_SSL_ENABLED=false
MYSQL_SSL_CA=/path/to/ca-cert.pem
MYSQL_SSL_CERT=/path/to/client-cert.pem
MYSQL_SSL_KEY=/path/to/client-key.pem

# Network Security
MYSQL_BIND_ADDRESS=0.0.0.0
MYSQL_ALLOWED_HOSTS=%

# =============================================================================
# Logging Configuration
# =============================================================================
MYSQL_SLOW_QUERY_LOG=true
MYSQL_SLOW_QUERY_LOG_FILE=/var/log/mysql/slow-query.log
MYSQL_GENERAL_LOG=false
MYSQL_GENERAL_LOG_FILE=/var/log/mysql/general.log
MYSQL_ERROR_LOG=/var/log/mysql/error.log

# =============================================================================
# Docker Configuration
# =============================================================================
MYSQL_CONTAINER_IMAGE=percona:8.0
PROXYSQL_CONTAINER_IMAGE=proxysql/proxysql:2.5

# Volume Paths
MYSQL_DATA_PATH=/srv/mysql
MYSQL_LOG_PATH=/var/log/mysql
BACKUP_PATH=/srv/backups/mysql

# Network
MYSQL_NETWORK=agl-mysql-ha
PROXYSQL_NETWORK=agl-mysql-ha

# =============================================================================
# High Availability Settings
# =============================================================================
# Semi-Synchronous Replication
MYSQL_SEMI_SYNC_MASTER_ENABLED=1
MYSQL_SEMI_SYNC_SLAVE_ENABLED=1
MYSQL_SEMI_SYNC_WAIT_NO_SLAVE=true

# GTID Mode
MYSQL_GTID_MODE=ON
MYSQL_ENFORCE_GTID_CONSISTENCY=ON

# Slave Configuration
MYSQL_SLAVE_PARALLEL_WORKERS=4
MYSQL_SLAVE_PARALLEL_TYPE=LOGICAL_CLOCK
MYSQL_SLAVE_PRESERVE_COMMIT_ORDER=true

# =============================================================================
# Application-Specific Settings
# =============================================================================
# Laravel Horizon (Queue Workers)
HORIZON_MYSQL_CONNECTION=mysql_master
HORIZON_MAX_CONNECTIONS=50

# Scheduler
SCHEDULER_MYSQL_CONNECTION=mysql_master
SCHEDULER_MAX_CONNECTIONS=10

# Read-Only Queries (force to slaves)
READ_ONLY_QUERIES=SELECT,SHOW,DESCRIBE,EXPLAIN

# =============================================================================
# Development/Testing
# =============================================================================
# Enable query logging in development
MYSQL_DEBUG=false
MYSQL_EXPLAIN_QUERIES=false

# Allow writes on slaves (for testing only!)
MYSQL_SLAVE_READ_ONLY=true
MYSQL_SLAVE_SUPER_READ_ONLY=true

# =============================================================================
# Notes
# =============================================================================
#
# Security Best Practices:
# 1. Use strong, unique passwords (minimum 32 characters)
# 2. Store production credentials in a secure vault
# 3. Rotate credentials regularly (every 90 days recommended)
# 4. Never commit .env files to version control
# 5. Use different credentials for dev/staging/production
# 6. Enable SSL/TLS for replication in production
# 7. Restrict MYSQL_ALLOWED_HOSTS in production
#
# Connection Strategy:
# - Writes go to DB_WRITE_HOST (ProxySQL port 6032 -> MySQL Master)
# - Reads go to DB_READ_HOST (ProxySQL port 6033 -> MySQL Slaves)
# - Failover: Switch to mysql_master or mysql_slave_* connections
#
# Monitoring:
# - PhpMyAdmin: http://localhost:8084
# - Prometheus: http://localhost:9090
# - Grafana: http://localhost:3000
# - ProxySQL Admin: mysql -h localhost -P 6080 -u admin -padmin
#
# =============================================================================
