APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

# Laravel Reverb Configuration
REVERB_APP_ID=agl-hostman
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb Frontend Configuration
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Proxmox VE API Configuration
PROXMOX_HOST=192.168.0.245
PROXMOX_PORT=8006
PROXMOX_USERNAME=root@pam
PROXMOX_PASSWORD=
PROXMOX_REALM=pam
PROXMOX_VERIFY_SSL=false
PROXMOX_LOG_CHANNEL=default
PROXMOX_DEFAULT_NODE=AGLSRV1

# Proxmox Cluster Nodes
PROXMOX_NODE1_HOST=192.168.0.245
PROXMOX_NODE1_WG=10.6.0.11
PROXMOX_NODE1_TS=100.107.113.33
PROXMOX_NODE2_WG=10.6.0.12

# Proxmox Performance & Reliability
PROXMOX_CACHE_ENABLED=true
PROXMOX_CACHE_TTL=300
PROXMOX_RATE_LIMIT_ENABLED=true
PROXMOX_RATE_LIMIT_MAX=100
PROXMOX_RATE_LIMIT_MINUTES=1
PROXMOX_CIRCUIT_BREAKER_ENABLED=true
PROXMOX_CIRCUIT_BREAKER_THRESHOLD=5
PROXMOX_CIRCUIT_BREAKER_TIMEOUT=300

# Monitoring Dashboard Configuration
MONITORING_POLL_INTERVAL=10      # Livewire polling interval (seconds)
MONITORING_CACHE_TTL=10          # Metrics cache TTL (seconds)
MONITORING_API_TIMEOUT=5         # Proxmox API timeout (seconds)
MONITORING_RETRY_ATTEMPTS=3      # API retry attempts
MONITORING_WEBSOCKET_ENABLED=true # Enable WebSocket updates
MONITORING_EXPORT_ENABLED=true   # Enable metrics export
MONITORING_AUTO_REFRESH=true     # Enable auto-refresh by default

# Network Topology Visualizer Configuration (Phase 3)
NETWORK_TOPOLOGY_CACHE_TTL=300        # Graph data cache TTL (5 minutes)
NETWORK_TOPOLOGY_MAX_NODES=500        # Maximum nodes to render
NETWORK_TOPOLOGY_LAYOUT_DEFAULT=cose-bilkent  # Default layout algorithm
NETWORK_TOPOLOGY_ENABLE_3D=false      # Enable 3D mode (requires additional library)
NETWORK_TOPOLOGY_LATENCY_THRESHOLD_GOOD=20    # Latency threshold for "good" (ms)
NETWORK_TOPOLOGY_LATENCY_THRESHOLD_FAIR=50    # Latency threshold for "fair" (ms)
NETWORK_TOPOLOGY_LATENCY_THRESHOLD_POOR=100   # Latency threshold for "poor" (ms)
NETWORK_TOPOLOGY_PACKET_LOSS_THRESHOLD=5      # Packet loss warning threshold (%)
NETWORK_TOPOLOGY_AUTO_REFRESH_INTERVAL=30     # Auto-refresh interval (seconds)
NETWORK_TOPOLOGY_ANIMATION_DURATION=1000      # Layout animation duration (ms)

# ========== QA Environment Configuration ==========
QA_ENABLED=true
QA_DOKPLOY_PROJECT_ID=
QA_HARBOR_PROJECT=agl-hostman-qa
QA_DOMAIN=qa-agl.aglz.io

# ========== Dokploy Configuration ==========
DOKPLOY_API_URL=http://192.168.0.180:3000
DOKPLOY_API_TOKEN=
DOKPLOY_WEBHOOK_TOKEN=

# ========== Harbor Registry Configuration ==========
HARBOR_REGISTRY=harbor.aglz.io:5000
HARBOR_USERNAME=admin
HARBOR_PASSWORD=

# ========== GitHub Webhook Configuration ==========
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_ENABLED=true

# ========== Deployment Configuration ==========
DEPLOYMENT_TIMEOUT=300
DEPLOYMENT_ROLLBACK_ON_FAILURE=true
DEPLOYMENT_RUN_TESTS=true
DEPLOYMENT_LOG_CHANNEL=deployments

# ========================================
# UAT Environment Configuration (CT181)
# Phase 3.2: Manual Promotion Workflow
# ========================================

# UAT Dokploy Settings
UAT_DOKPLOY_URL=http://192.168.0.181:3000
UAT_DOKPLOY_TOKEN=

# UAT Harbor Settings
UAT_HARBOR_PROJECT=agl-hostman-uat

# UAT Domain
UAT_DOMAIN=uat-agl.aglz.io

# UAT Database
UAT_DB_DATABASE=agl_hostman_uat

# UAT Approval Settings
UAT_APPROVAL_REQUIRED=true
UAT_APPROVER_ROLES=admin,lead-developer

# UAT Deployment Settings
UAT_AUTO_DEPLOY=false
UAT_AUTO_TEST=true
UAT_TEST_TYPE=smoke
UAT_ROLLBACK_ON_FAILURE=true

# Promotion Workflow Settings
PROMOTION_APPROVAL_TIMEOUT=86400  # 24 hours
PROMOTION_NOTIFY_CHANNELS=slack,email
PROMOTION_SLACK_WEBHOOK=
PROMOTION_EMAIL_RECIPIENTS=

# Smoke Test Configuration
SMOKE_TEST_TIMEOUT=120  # 2 minutes
SMOKE_TEST_PARALLEL=true
SMOKE_TEST_STOP_ON_FAILURE=true
