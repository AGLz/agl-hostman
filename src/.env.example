# -----------------------------------------------------------------------------
# Copiar para .env e ajustar:  cp .env.example .env
# Gerar APP_KEY:  php artisan key:generate   (requer PHP/Artisan funcional)
# -----------------------------------------------------------------------------

APP_NAME=agl-hostman
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=pt
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de dados local (SQLite). Para MySQL, ver docker-compose.yml.
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
MAIL_MAILER=log

TELESCOPE_ENABLED=false

# --- Variáveis do projeto (infra / integrações) ---
HOSTMAN_PORT=3030
HOSTMAN_API_KEY=

PROXMOX_HOST=192.168.0.245
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=

LITELLM_BASE_URL=http://100.125.249.8:4000
LITELLM_MASTER_KEY=
OPENCLAW_BASE_URL=http://100.123.184.125:28789
OPENCLAW_REMOTE_STATUS_ENABLED=true
OPENCLAW_CHAT_TRANSPORT=ssh-docker
OPENCLAW_SSH_HOST=root@100.123.184.125
OPENCLAW_DOCKER_CONTAINER=agl-openclaw-openclaw-gateway-1
OPENCLAW_SSH_CONNECT_TIMEOUT=8
OPENCLAW_CHAT_BASE_URL=http://100.123.184.125:28789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_CHAT_TIMEOUT=90

# Hermes Mission Control (CT188 quartet — substitui OpenClaw no dashboard Laravel)
HERMES_API_BASE_URL=http://100.81.225.22:8642
HERMES_API_KEY=
HERMES_MINIONS_BASE_URL=http://100.81.225.22:6969
HERMES_STUDIO_BASE_URL=http://100.81.225.22:3003
HERMES_CLAW3D_WS_URL=ws://100.81.225.22:18789
HERMES_DASHBOARD_BASE_URL=http://100.81.225.22:9119
HERMES_STUDIO_ACCESS_TOKEN=

STORAGE_ALERT_THRESHOLD=90

WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=

# auth.md — registo de agentes (https://workos.com/auth-md); activo se WORKOS_* preenchido
AUTH_MD_ENABLED=
AUTH_MD_AUTH_SERVER_URL=
AUTH_MD_RESOURCE_URL=
AUTH_MD_TRUSTED_ISSUERS=
AUTH_MD_CONTACT_EMAIL=authmd@workos.com

