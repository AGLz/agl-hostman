APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================================
# MULTI-DATABASE CONFIGURATION
# ============================================================================

# Primary Database Connection (choose one: sqlite, mysql, pgsql)
DB_CONNECTION=sqlite

# SQLite Configuration (for testing/local development)
DB_SQLITE_PATH=database/database.sqlite

# MySQL 8.0 Configuration
DB_MYSQL_HOST=127.0.0.1
DB_MYSQL_PORT=3307
DB_MYSQL_DATABASE=agl_hostman
DB_MYSQL_USERNAME=agl_user
DB_MYSQL_PASSWORD=secret
DB_MYSQL_PREFIX=mysql_

# MySQL Root Access (for administration)
MYSQL_ROOT_PASSWORD=root_secret

# PostgreSQL Configuration
DB_PGSQL_HOST=127.0.0.1
DB_PGSQL_PORT=5432
DB_PGSQL_DATABASE=agl_hostman
DB_PGSQL_USERNAME=agl_user
DB_PGSQL_PASSWORD=secret
DB_PGSQL_PREFIX=pgsql_

# Legacy Database Configuration (backward compatibility)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

# Laravel Reverb Configuration
REVERB_APP_ID=agl-hostman
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# ============================================================================
# REDIS 7 CONFIGURATION
# ============================================================================

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# Redis Database Selection
REDIS_DB=0              # Default database
REDIS_CACHE_DB=1        # Cache database
REDIS_SESSION_DB=2      # Session database
REDIS_QUEUE_DB=3        # Queue database (Laravel Horizon)

# Redis Connection Options
REDIS_PREFIX=agl_hostman_
REDIS_PERSISTENT=false
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000

# Redis Cluster (optional)
# REDIS_CLUSTER=redis
# REDIS_CLUSTER_HOSTS=127.0.0.1:7000,127.0.0.1:7001,127.0.0.1:7002

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb Frontend Configuration
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Proxmox VE API Configuration
PROXMOX_HOST=192.168.0.245
PROXMOX_PORT=8006
PROXMOX_USERNAME=root@pam
PROXMOX_PASSWORD=
PROXMOX_REALM=pam
PROXMOX_VERIFY_SSL=false
PROXMOX_LOG_CHANNEL=default
PROXMOX_DEFAULT_NODE=AGLSRV1

# Proxmox Cluster Nodes
PROXMOX_NODE1_HOST=192.168.0.245
PROXMOX_NODE1_WG=10.6.0.11
PROXMOX_NODE1_TS=100.107.113.33
PROXMOX_NODE2_WG=10.6.0.12

# Proxmox Performance & Reliability
PROXMOX_CACHE_ENABLED=true
PROXMOX_CACHE_TTL=300
PROXMOX_RATE_LIMIT_ENABLED=true
PROXMOX_RATE_LIMIT_MAX=100
PROXMOX_RATE_LIMIT_MINUTES=1
PROXMOX_CIRCUIT_BREAKER_ENABLED=true
PROXMOX_CIRCUIT_BREAKER_THRESHOLD=5
PROXMOX_CIRCUIT_BREAKER_TIMEOUT=300

# Monitoring Dashboard Configuration
MONITORING_POLL_INTERVAL=10      # Livewire polling interval (seconds)
MONITORING_CACHE_TTL=10          # Metrics cache TTL (seconds)
MONITORING_API_TIMEOUT=5         # Proxmox API timeout (seconds)
MONITORING_RETRY_ATTEMPTS=3      # API retry attempts
MONITORING_WEBSOCKET_ENABLED=true # Enable WebSocket updates
MONITORING_EXPORT_ENABLED=true   # Enable metrics export
MONITORING_AUTO_REFRESH=true     # Enable auto-refresh by default

# Network Topology Visualizer Configuration (Phase 3)
NETWORK_TOPOLOGY_CACHE_TTL=300        # Graph data cache TTL (5 minutes)
NETWORK_TOPOLOGY_MAX_NODES=500        # Maximum nodes to render
NETWORK_TOPOLOGY_LAYOUT_DEFAULT=cose-bilkent  # Default layout algorithm
NETWORK_TOPOLOGY_ENABLE_3D=false      # Enable 3D mode (requires additional library)
NETWORK_TOPOLOGY_LATENCY_THRESHOLD_GOOD=20    # Latency threshold for "good" (ms)
NETWORK_TOPOLOGY_LATENCY_THRESHOLD_FAIR=50    # Latency threshold for "fair" (ms)
NETWORK_TOPOLOGY_LATENCY_THRESHOLD_POOR=100   # Latency threshold for "poor" (ms)
NETWORK_TOPOLOGY_PACKET_LOSS_THRESHOLD=5      # Packet loss warning threshold (%)
NETWORK_TOPOLOGY_AUTO_REFRESH_INTERVAL=30     # Auto-refresh interval (seconds)
NETWORK_TOPOLOGY_ANIMATION_DURATION=1000      # Layout animation duration (ms)

# ========== QA Environment Configuration ==========
QA_ENABLED=true
QA_DOKPLOY_PROJECT_ID=
QA_HARBOR_PROJECT=agl-hostman-qa
QA_DOMAIN=qa-agl.aglz.io

# ========== Dokploy Configuration ==========
DOKPLOY_API_URL=http://192.168.0.180:3000
DOKPLOY_API_TOKEN=
DOKPLOY_WEBHOOK_TOKEN=

# ========== Harbor Registry Configuration ==========
HARBOR_REGISTRY=harbor.aglz.io:5000
HARBOR_USERNAME=admin
HARBOR_PASSWORD=

# ========== GitHub Webhook Configuration ==========
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_ENABLED=true

# ========== Deployment Configuration ==========
DEPLOYMENT_TIMEOUT=300
DEPLOYMENT_ROLLBACK_ON_FAILURE=true
DEPLOYMENT_RUN_TESTS=true
DEPLOYMENT_LOG_CHANNEL=deployments

# ========================================
# UAT Environment Configuration (CT181)
# Phase 3.2: Manual Promotion Workflow
# ========================================

# UAT Dokploy Settings
UAT_DOKPLOY_URL=http://192.168.0.181:3000
UAT_DOKPLOY_TOKEN=

# UAT Harbor Settings
UAT_HARBOR_PROJECT=agl-hostman-uat

# UAT Domain
UAT_DOMAIN=uat-agl.aglz.io

# UAT Database
UAT_DB_DATABASE=agl_hostman_uat

# UAT Approval Settings
UAT_APPROVAL_REQUIRED=true
UAT_APPROVER_ROLES=admin,lead-developer

# UAT Deployment Settings
UAT_AUTO_DEPLOY=false
UAT_AUTO_TEST=true
UAT_TEST_TYPE=smoke
UAT_ROLLBACK_ON_FAILURE=true

# Promotion Workflow Settings
PROMOTION_APPROVAL_TIMEOUT=86400  # 24 hours
PROMOTION_NOTIFY_CHANNELS=slack,email
PROMOTION_SLACK_WEBHOOK=
PROMOTION_EMAIL_RECIPIENTS=

# Smoke Test Configuration
SMOKE_TEST_TIMEOUT=120  # 2 minutes
SMOKE_TEST_PARALLEL=true
SMOKE_TEST_STOP_ON_FAILURE=true

# ========================================
# Production Environment Configuration (CT182)
# Phase 3.3: Blue-Green High Availability
# ========================================

# Production Dokploy Settings (CT182 or CT181 with HA)
PRODUCTION_DOKPLOY_URL=http://192.168.0.182:3000
PRODUCTION_DOKPLOY_TOKEN=

# Production Harbor Settings
PRODUCTION_HARBOR_PROJECT=agl-hostman-prod

# Production Domains
PRODUCTION_DOMAINS=prod-agl.aglz.io,agl-hostman.aglz.io

# Production Database
PRODUCTION_DB_DATABASE=agl_hostman_prod
PRODUCTION_DB_USERNAME=
PRODUCTION_DB_PASSWORD=
PRODUCTION_REPLICATION_PASSWORD=

# Production Redis
PRODUCTION_REDIS_PASSWORD=

# Production HA Configuration
PRODUCTION_REPLICAS=2
PRODUCTION_DEPLOYMENT_TYPE=blue_green

# Production Approval Settings (2-Level)
PRODUCTION_APPROVAL_REQUIRED=true
PRODUCTION_APPROVERS=lead-developer,admin
PRODUCTION_MIN_APPROVALS=2
PRODUCTION_APPROVAL_TIMEOUT=86400  # 24 hours

# Blue-Green Deployment Configuration
BLUE_GREEN_ENABLED=true
ACTIVE_SLOT=blue
BLUE_VERSION=
GREEN_VERSION=
TRAFFIC_SWITCH_GRADUAL=true
TRAFFIC_SWITCH_INTERVALS=10,50,100  # Percentage intervals

# Production Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_URL=https://grafana.aglz.io
GRAFANA_PASSWORD=
ALERT_EMAIL=ops@agl.com
ALERT_SLACK_WEBHOOK=
ALERT_ERROR_RATE_THRESHOLD=0.01  # 1%
ALERT_RESPONSE_TIME_THRESHOLD=500  # ms
ALERT_DB_POOL_THRESHOLD=0.8  # 80%
ALERT_DISK_SPACE_THRESHOLD=0.2  # 20% free
ALERT_MEMORY_THRESHOLD=0.85  # 85%

# Production Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_INCREMENTAL_SCHEDULE=0 * * * *  # Hourly
BACKUP_INCREMENTAL_RETENTION_DAYS=7
BACKUP_STORAGE=s3
BACKUP_S3_BUCKET=agl-hostman-backups
BACKUP_VERIFY_ENABLED=true
BACKUP_TEST_RESTORE_MONTHLY=true

# Production Security
PRODUCTION_WAF_ENABLED=true
PRODUCTION_RATE_LIMIT_MAX=100
PRODUCTION_RATE_LIMIT_WINDOW=60
PRODUCTION_IP_WHITELIST_ADMIN=
PRODUCTION_AUDIT_LOG_ENABLED=true
PRODUCTION_SECRETS_ROTATION_DAYS=90
PRODUCTION_SSL_ENFORCE=true
PRODUCTION_HSTS_ENABLED=true

# Production Performance
PRODUCTION_CPU_CORES=4
PRODUCTION_MEMORY_MB=8192
PRODUCTION_DISK_GB=100
PRODUCTION_MAX_CONNECTIONS=100
PRODUCTION_QUERY_TIMEOUT=30

# Rollback Configuration
ROLLBACK_TARGET_MTTR=120  # 2 minutes (in seconds)
ROLLBACK_KEEP_PREVIOUS=true
ROLLBACK_WINDOW_HOURS=1

# Load Balancer Configuration
PRODUCTION_LB_TYPE=nginx
PRODUCTION_LB_ALGORITHM=least_conn
PRODUCTION_LB_HEALTH_CHECK_PATH=/health
PRODUCTION_LB_HEALTH_CHECK_INTERVAL=30
PRODUCTION_LB_API=https://lb.prod-agl.aglz.io

# Notification Settings
DEPLOYMENT_EMAIL_RECIPIENTS=
DEPLOYMENT_SLACK_CHANNEL=
DEPLOYMENT_NOTIFY_ON_SUCCESS=true
DEPLOYMENT_NOTIFY_ON_FAILURE=true
DEPLOYMENT_NOTIFY_ON_ROLLBACK=true

# Disaster Recovery
DR_ENABLED=true
DR_RTO_HOURS=1  # Recovery Time Objective
DR_RPO_HOURS=1  # Recovery Point Objective
DR_SECONDARY_REGION=us-west-2
DR_FAILOVER_MANUAL=true

# ============================================================================
# PHASE 3.4: ENVIRONMENT PROMOTION AUTOMATION
# ============================================================================

# GitHub Webhook Configuration
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret-here

# Promotion Workflow Configuration
PROMOTION_AUTO_DEV_TO_QA=true
PROMOTION_QA_TO_UAT_APPROVALS=1
PROMOTION_UAT_TO_PROD_APPROVALS=2
PROMOTION_APPROVAL_TIMEOUT_HOURS=24
PROMOTION_QA_STABILITY_HOURS=24
PROMOTION_UAT_STABILITY_HOURS=72

# Notification Configuration
NOTIFICATION_CHANNELS=email,slack
SLACK_PROMOTIONS_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
PROMOTION_EMAIL_FROM=deployments@agl.com
PROMOTION_ALERT_EMAIL=ops@agl.com

# Alert Configuration (Multi-channel)
ALERTS_SLACK_ENABLED=true
ALERTS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

ALERTS_DISCORD_ENABLED=false
ALERTS_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/ID/TOKEN

ALERTS_EMAIL_ENABLED=true
ALERTS_EMAIL_RECIPIENTS=admin@example.com,ops@example.com

