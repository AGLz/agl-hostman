# =============================================================================
# MySQL Master Configuration for AGL Hostman
# GTID-based replication with binary logging
# =============================================================================
[mysqld]
# -----------------------------------------------------------------------------
# Server Identification
# -----------------------------------------------------------------------------
server-id = 1
bind-address = 0.0.0.0
port = 3306

# -----------------------------------------------------------------------------
# Data Directory
# -----------------------------------------------------------------------------
datadir = /var/lib/mysql
socket = /var/lib/mysql/mysql.sock

# -----------------------------------------------------------------------------
# GTID Configuration (Global Transaction IDs)
# -----------------------------------------------------------------------------
# Enable GTID for easier failover and recovery
gtid_mode = ON
enforce_gtid_consistency = ON

# -----------------------------------------------------------------------------
# Binary Logging
# -----------------------------------------------------------------------------
# Row-based replication for better consistency
binlog_format = ROW
binlog_rows_query_log_events = ON

# Binary log files
log-bin = /var/lib/mysql/mysql-bin
log-bin-index = /var/lib/mysql/mysql-bin.index
max_binlog_size = 1G

# Binary log retention (7 days for PITR)
binlog_expire_logs_seconds = 604800

# Binary log caching
binlog_cache_size = 4M
max_binlog_cache_size = 512M

# -----------------------------------------------------------------------------
# Replication Settings
# -----------------------------------------------------------------------------
# Semi-synchronous replication for data safety
plugin-load = rpl_semi_sync_master=semisync_master.so
rpl_semi_sync_master_enabled = 1
rpl_semi_sync_master_timeout = 1000

# Number of slaves that must acknowledge
rpl_semi_sync_master_wait_no_slave = ON

# Slave parallel execution
slave_parallel_type = LOGICAL_CLOCK
slave_parallel_workers = 4

# Replication filters (replicate all databases)
# replicate-do-db = agl_hostman_prod

# -----------------------------------------------------------------------------
# InnoDB Configuration
# -----------------------------------------------------------------------------
# Buffer pool size (adjust based on available RAM)
innodb_buffer_pool_size = 4G
innodb_buffer_pool_instances = 4
innodb_file_per_table = ON

# Flush settings
innodb_flush_log_at_trx_commit = 1
innodb_flush_method = O_DIRECT

# Log settings
innodb_log_file_size = 512M
innodb_log_files_in_group = 2
innodb_log_buffer_size = 16M

# I/O settings
innodb_io_capacity = 2000
innodb_io_capacity_max = 4000
innodb_read_io_threads = 8
innodb_write_io_threads = 8

# -----------------------------------------------------------------------------
# Connection Settings
# -----------------------------------------------------------------------------
max_connections = 500
max_connect_errors = 10000
connect_timeout = 10
wait_timeout = 600
interactive_timeout = 600

# -----------------------------------------------------------------------------
# Cache Settings
# -----------------------------------------------------------------------------
table_open_cache = 4000
table_definition_cache = 2000
thread_cache_size = 100
query_cache_size = 0
query_cache_type = 0

# -----------------------------------------------------------------------------
# Slow Query Log
# -----------------------------------------------------------------------------
slow_query_log = ON
slow_query_log_file = /var/log/mysql/slow-query.log
long_query_time = 2
log_queries_not_using_indexes = ON

# -----------------------------------------------------------------------------
# Error Logging
# -----------------------------------------------------------------------------
log_error = /var/log/mysql/error.log
log_error_verbosity = 2

# -----------------------------------------------------------------------------
# General Query Log (disable in production)
# -----------------------------------------------------------------------------
general_log = OFF

# -----------------------------------------------------------------------------
# Character Set
# -----------------------------------------------------------------------------
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
# Require explicit privilege revokes
symbolic_links = 0
local_infile = 0

# SQL mode
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# -----------------------------------------------------------------------------
# Performance Schema
# -----------------------------------------------------------------------------
performance_schema = ON
performance_schema_instrument = '%=ON'

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
# Enable replication monitoring
userstat = ON
