# =============================================================================
# MySQL Slave Configuration for AGL Hostman
# GTID-based replication with read-only mode
# =============================================================================
[mysqld]
# -----------------------------------------------------------------------------
# Server Identification (each slave has unique ID)
# -----------------------------------------------------------------------------
server-id = 2  # Change to 3 for second slave
bind-address = 0.0.0.0
port = 3306
read_only = ON
super_read_only = ON

# -----------------------------------------------------------------------------
# Data Directory
# -----------------------------------------------------------------------------
datadir = /var/lib/mysql
socket = /var/lib/mysql/mysql.sock

# -----------------------------------------------------------------------------
# GTID Configuration
# -----------------------------------------------------------------------------
gtid_mode = ON
enforce_gtid_consistency = ON

# -----------------------------------------------------------------------------
# Binary Logging (for chained replication)
# -----------------------------------------------------------------------------
binlog_format = ROW
binlog_rows_query_log_events = ON
log-bin = /var/lib/mysql/mysql-bin
log-bin-index = /var/lib/mysql/mysql-bin.index
max_binlog_size = 1G
binlog_expire_logs_seconds = 604800

# -----------------------------------------------------------------------------
# Relay Log Configuration
# -----------------------------------------------------------------------------
relay-log = /var/lib/mysql/relay-bin
relay-log-index = /var/lib/mysql/relay-bin.index
relay_log_purge = ON
relay_log_recovery = ON
max_relay_log_size = 1G

# Relay log repository (GTID-based)
relay_log_info_repository = TABLE
master_info_repository = TABLE

# -----------------------------------------------------------------------------
# Replication Settings
# -----------------------------------------------------------------------------
# Semi-synchronous replication slave
plugin-load = rpl_semi_sync_slave=semisync_slave.so
rpl_semi_sync_slave_enabled = 1

# Slave parallel execution
slave_parallel_type = LOGICAL_CLOCK
slave_parallel_workers = 4
slave_preserve_commit_order = ON

# Slave checkpoints
slave_checkpoint_group = 512
slave_checkpoint_period = 300

# Prevent replication of temporary tables
replicate_tmp_table = OFF

# Replication filters
# replicate-do-db = agl_hostman_prod

# -----------------------------------------------------------------------------
# Skip Slave Errors (use with caution)
# -----------------------------------------------------------------------------
slave_skip_errors = 1062,1032

# -----------------------------------------------------------------------------
# InnoDB Configuration
# -----------------------------------------------------------------------------
innodb_buffer_pool_size = 4G
innodb_buffer_pool_instances = 4
innodb_file_per_table = ON
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
innodb_log_file_size = 512M
innodb_log_files_in_group = 2
innodb_log_buffer_size = 16M
innodb_io_capacity = 2000
innodb_io_capacity_max = 4000
innodb_read_io_threads = 8
innodb_write_io_threads = 8

# -----------------------------------------------------------------------------
# Connection Settings
# -----------------------------------------------------------------------------
max_connections = 500
max_connect_errors = 10000
connect_timeout = 10
wait_timeout = 600
interactive_timeout = 600

# -----------------------------------------------------------------------------
# Cache Settings
# -----------------------------------------------------------------------------
table_open_cache = 4000
table_definition_cache = 2000
thread_cache_size = 100
query_cache_size = 0
query_cache_type = 0

# -----------------------------------------------------------------------------
# Slow Query Log
# -----------------------------------------------------------------------------
slow_query_log = ON
slow_query_log_file = /var/log/mysql/slow-query.log
long_query_time = 2
log_queries_not_using_indexes = ON

# -----------------------------------------------------------------------------
# Error Logging
# -----------------------------------------------------------------------------
log_error = /var/log/mysql/error.log
log_error_verbosity = 2
log_slave_updates = ON

# -----------------------------------------------------------------------------
# Character Set
# -----------------------------------------------------------------------------
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# -----------------------------------------------------------------------------
# SQL Mode
# -----------------------------------------------------------------------------
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# -----------------------------------------------------------------------------
# Performance Schema
# -----------------------------------------------------------------------------
performance_schema = ON

# -----------------------------------------------------------------------------
# Replication Health Monitoring
# -----------------------------------------------------------------------------
# Enable replication monitoring tables
userstat = ON
