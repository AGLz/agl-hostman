# =============================================================================
# MySQL HA Replication Configuration
# AGL Hostman - Environment Configuration for Replication Setup
# =============================================================================
#
# Copy this file to replication-config.env and update with your values
# DO NOT commit actual passwords to version control
#
# =============================================================================

# =============================================================================
# MySQL Host Configuration
# =============================================================================
MYSQL_MASTER_HOST=mysql-master
MYSQL_SLAVE_HOSTS=mysql-slave-1,mysql-slave-2
MYSQL_PORT=3306

# =============================================================================
# MySQL Credentials
# =============================================================================
MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_USER=agl_user
MYSQL_PASSWORD=changeme_user_password
MYSQL_DATABASE=agl_hostman

# =============================================================================
# Replication Configuration
# =============================================================================
MYSQL_REPLICATION_USER=replicator
MYSQL_REPLICATION_PASSWORD=changeme_replication_password

# =============================================================================
# Failover Configuration
# =============================================================================
FAILOVER_CHECK_INTERVAL=10
FAILOVER_TIMEOUT=60
MAX_REPLICATION_LAG=30

# =============================================================================
# Alert Configuration
# =============================================================================
ALERT_EMAIL=alerts@agl.local
ALERT_WEBHOOK=
SLACK_WEBHOOK=

# =============================================================================
# Backup Configuration
# =============================================================================
BACKUP_ROOT=/backups
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE="0 2 * * *"

# =============================================================================
# S3 Configuration (Optional)
# =============================================================================
S3_UPLOAD=false
S3_BUCKET=
S3_PREFIX=mysql-backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
