# =============================================================================
# Production Environment Configuration
# AGL Hostman - Terraform Infrastructure
# =============================================================================

# Environment
environment = "production"
project_name = "agl-hostman"
region       = "agl-primary"

# =============================================================================
# Proxmox Configuration
# =============================================================================
proxmox_api_url          = "https://192.168.0.245:8006/api2/json"
proxmox_api_token_id     = "terraform@pve!production"
proxmox_api_token_secret = "CHANGE_ME-production-token-secret"
proxmox_tls_insecure     = false
proxmox_timeout          = 600

# =============================================================================
# Network Configuration
# =============================================================================
network_config = {
  bridge         = "vmbr0"
  gateway        = "192.168.0.1"
  dns_servers    = ["192.168.0.1", "8.8.8.8", "8.8.4.4"]
  search_domains = ["agl.local", "aglz.io", "internal"]
}

wireguard_config = {
  enabled = true
  network = "10.6.0.0/24"
  port    = 51820
  peers   = {
    aglsrv1 = {
      public_key = "CHANGE_ME-public-key-1"
      endpoint   = "192.168.0.245:51820"
      allowed_ip = "10.6.0.11/32"
    }
    aglsrv6 = {
      public_key = "CHANGE_ME-public-key-2"
      endpoint   = "192.168.0.246:51820"
      allowed_ip = "10.6.0.12/32"
    }
  }
}

# =============================================================================
# Storage Configuration
# =============================================================================
storage_config = {
  local-lvm = {
    type        = "lvm"
    storage     = "local-lvm"
    content     = ["images", "rootdir"]
    shared      = false
    backup_pool = false
  }
  local-btrfs = {
    type        = "btrfs"
    storage     = "local-btrfs"
    content     = ["images", "rootdir", "vztmpl", "backup", "iso"]
    shared      = false
    backup_pool = false
  }
  nfs-storage = {
    type        = "nfs"
    storage     = "nfs-storage"
    content     = ["images", "backup", "iso"]
    shared      = true
    backup_pool = true
  }
}

default_storage  = "local-lvm"
backup_storage  = "nfs-storage"

# =============================================================================
# VM Configuration Defaults
# =============================================================================
default_vm_config = {
  cpu_cores     = 2
  cpu_sockets   = 1
  cpu_type      = "host"
  memory_gb     = 4
  scsi_hardware = "virtio-scsi-pci"
  bios          = "seabios"
  os_type       = "ubuntu22.04"

  disk = {
    interface = "scsi"
    ssd       = true
    discard   = true
    cache     = "writeback"
    backup    = true
  }

  network = {
    model    = "virtio"
    bridge   = "vmbr0"
    firewall = true
  }
}

# =============================================================================
# Container Configuration Defaults
# =============================================================================
default_lxc_config = {
  cpu_cores     = 2
  cpu_units     = 1024
  memory_mb     = 2048
  swap_mb       = 512
  unprivileged  = true
  onboot        = true

  features = {
    nesting = true
    keyctl  = true
    fuse    = true
  }

  storage = {
    storage  = "local-lvm"
    type     = "rootdir"
    size_gb  = 32
  }
}

# =============================================================================
# Production VMs
# =============================================================================
production_vms = {
  harbor = {
    vm_name    = "harbor-registry"
    vm_id      = 182
    node_name  = "AGLSRV1"

    cpu_cores = 4
    memory_gb = 8

    disks = [
      {
        type         = "scsi0"
        storage      = "local-lvm"
        storage_type = "lvm"
        size_gb      = 128
      }
    ]

    network = {
      ip      = "192.168.0.182"
      gateway = "192.168.0.1"
    }

    tags = ["registry", "harbor", "production", "critical"]
  }

  dokploy = {
    vm_name    = "dokploy-platform"
    vm_id      = 180
    node_name  = "AGLSRV1"

    cpu_cores = 4
    memory_gb = 8

    disks = [
      {
        type         = "scsi0"
        storage      = "local-lvm"
        storage_type = "lvm"
        size_gb      = 64
      }
    ]

    network = {
      ip      = "192.168.0.180"
      gateway = "192.168.0.1"
    }

    tags = ["deployment", "dokploy", "production"]
  }
}

# =============================================================================
# Production LXC Containers
# =============================================================================
production_lxcs = {
  app = {
    container_name = "app-server"
    container_id   = 179
    node_name      = "AGLSRV1"

    cpu_cores = 4
    memory_mb = 8192

    storage = {
      storage  = "local-lvm"
      size_gb  = 64
    }

    features = {
      nesting = true
      keyctl  = true
    }

    network = {
      ip      = "192.168.0.179"
      gateway = "192.168.0.1"
    }

    tags = ["application", "production", "critical"]
  }

  monitoring = {
    container_name = "monitoring-stack"
    container_id   = 108
    node_name      = "AGLSRV1"

    cpu_cores = 2
    memory_mb = 4096

    storage = {
      storage  = "local-lvm"
      size_gb  = 32
    }

    features = {
      nesting = true
    }

    network = {
      ip      = "192.168.0.108"
      gateway = "192.168.0.1"
    }

    tags = ["monitoring", "prometheus", "grafana", "alertmanager"]
  }
}

# =============================================================================
# Docker Registry Configuration
# =============================================================================
docker_registry = {
  enabled     = true
  registry_name     = "agl-registry"
  registry_port     = 5000
  registry_ui_port  = 8080
  registry_ui_enabled = true

  auth_enabled    = true
  tls_enabled     = true

  storage_driver  = "filesystem"
  data_dir       = "/var/lib/registry"
}

# =============================================================================
# HA Configuration
# =============================================================================
ha_config = {
  enabled = true

  load_balancer = {
    enabled     = true
    vm_id       = 183
    ip_address  = "192.168.0.183"
    vips        = ["192.168.0.250"]
  }

  database = {
    enabled     = true
    master_vm_id = 170
    master_ip    = "192.168.0.170"
    slave_vm_ids = [171, 172]
    slave_ips    = ["192.168.0.171", "192.168.0.172"]
  }

  redis = {
    enabled     = true
    nodes       = 3
    node_ids    = [160, 161, 162]
    node_ips    = ["192.168.0.160", "192.168.0.161", "192.168.0.162"]
    quorum      = 2
  }
}

# =============================================================================
# Backup Configuration
# =============================================================================
backup_config = {
  enabled            = true
  schedule          = "0 2 * * *"  # Daily at 2 AM
  retention_days    = 30
  compression       = true
  encryption_key    = "CHANGE_ME-backup-encryption-key"

  destinations = {
    local = {
      enabled   = true
      path      = "/mnt/backups"
    }
    nfs = {
      enabled   = true
      path      = "nfs-storage:/backups"
    }
    s3 = {
      enabled   = false
      bucket    = "agl-infrastructure-backups"
      region    = "us-east-1"
    }
  }
}

# =============================================================================
# Monitoring Configuration
# =============================================================================
monitoring_config = {
  enabled = true

  prometheus = {
    retention_days = 30
    scrape_interval = "15s"
  }

  grafana = {
    admin_password = "CHANGE_ME-grafana-admin-password"
  }

  alertmanager = {
    enabled     = true
    smtp_host   = "smtp.example.com"
    smtp_from   = "alerts@agl.io"
    smtp_to     = ["ops@agl.io"]
  }
}

# =============================================================================
# Security Configuration
# =============================================================================
security_config = {
  firewall_enabled = true

  allowed_ips = {
    management = ["10.6.0.0/24", "192.168.0.0/24"]
    vpn        = ["10.6.0.0/24"]
    services   = ["0.0.0.0/0"]  # All for web services
  }

  ssh = {
    allowed_users = ["admin", "deploy", "terraform"]
    key_based_only = true
  }
}

# =============================================================================
# Ansible Configuration
# =============================================================================
ansible_config = {
  playbook_path = "../ansible"
  inventory_path = "../ansible/inventory/production.ini"

  extra_vars = {
    env              = "production"
    domain           = "agl.io"
    monitoring_enabled = true
    backup_enabled    = true
  }
}
