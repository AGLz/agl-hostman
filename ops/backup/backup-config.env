# =============================================================================
# AGL Hostman - Backup Configuration
# =============================================================================
# Source this file before running backup scripts:
#   source backup-config.env
# =============================================================================

# =============================================================================
# Backup Storage
# =============================================================================
BACKUP_ROOT="/mnt/shares/agl-hostman-backups"
OFFSITE_TARGET="/mnt/storage/offsite/agl-hostman"

# =============================================================================
# Retention Policies (in days)
# =============================================================================
DAILY_RETENTION=7
WEEKLY_RETENTION=28   # 4 weeks
MONTHLY_RETENTION=365 # 12 months

# =============================================================================
# SLA Targets
# =============================================================================
RTO_TARGET_HOURS=4
RPO_TARGET_MINUTES=60

# =============================================================================
# Alert Settings
# =============================================================================
ALERT_EMAIL="admin@agl.local"
SLACK_WEBHOOK=""

# Offsite replication
OFFSITE_ENABLED=true
OFFSITE_HOST=""
OFFSITE_USER=""

# =============================================================================
# Backup Schedule
# =============================================================================
DAILY_BACKUP_TIME="02:00"
WEEKLY_BACKUP_DAY="0"  # 0=Sunday
MONTHLY_BACKUP_DAY="01"

# Health check interval (hours)
HEALTH_CHECK_INTERVAL_HOURS=6

# Maximum backup age before alert (hours)
MAX_BACKUP_AGE_HOURS=26

# =============================================================================
# Docker Containers to Backup
# =============================================================================
POSTGRES_CONTAINERS=("crowbar-postgres")
MARIADB_CONTAINERS=("api9-mariadb" "agl-admin-mysql")
REDIS_CONTAINERS=("crowbar-redis" "api9-redis" "agl-admin-redis")

# =============================================================================
# Docker Volumes to Backup
# =============================================================================
VOLUMES_TO_BACKUP=("agl-hostman-db-data" "agl-hostman-redis-data")

# =============================================================================
# Compression Settings
# =============================================================================
COMPRESSION_LEVEL=6
COMPRESSION_ALGORITHM="gzip"

# =============================================================================
# Encryption
# =============================================================================
ENCRYPT_ENV_FILE=true
ENCRYPTION_ALGORITHM="AES256"
GPG_RECIPIENT=""

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL="INFO"  # DEBUG, INFO, WARN, ERROR
LOG_RETENTION_DAYS=30

# =============================================================================
# Performance
# =============================================================================
PARALLEL_BACKUPS=true
MAX_PARALLEL_JOBS=3

# =============================================================================
# Testing
# =============================================================================
AUTO_TEST_RESTORE=true
TEST_SCHEDULE="weekly"  # daily, weekly, monthly

# =============================================================================
# Advanced
# =============================================================================
PRE_BACKUP_SCRIPT=""
POST_BACKUP_SCRIPT=""
ON_FAILURE_SCRIPT=""

# Bandwidth limit for rsync (KB/s)
RSYNC_BANDWIDTH_LIMIT=0  # 0 = unlimited

# Verify backups after creation
VERIFY_BACKUPS=true
