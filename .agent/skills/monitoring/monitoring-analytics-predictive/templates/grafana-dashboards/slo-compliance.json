{
  "dashboard": {
    "id": null,
    "title": "SLO/SLI Compliance",
    "tags": ["slo", "sli", "compliance"],
    "timezone": "browser",
    "schemaVersion": 36,
    "version": 0,
    "refresh": "1m",
    "panels": [
      {
        "id": 1,
        "title": "Availability SLO (99.9%)",
        "type": "stat",
        "targets": [
          {
            "expr": "(\n  sum(rate(app_requests_total{status!~\"5..\"}[5m]))\n  /\n  sum(rate(app_requests_total[5m]))\n) * 100",
            "legendFormat": "Availability"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 99,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 99.9, "color": "green" },
                { "value": 99.5, "color": "yellow" },
                { "value": 99, "color": "red" }
              ]
            },
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": { "text": "Target: 99.9%", "color": "semi-dark-blue" }
                }
              }
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "Error Budget Remaining",
        "type": "gauge",
        "targets": [
          {
            "expr": "(1 - (\n  sum(rate(app_errors_total[30d]))\n  /\n  sum(rate(app_requests_total[30d]))\n) / 0.001) * 100",
            "legendFormat": "Error Budget"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 25, "color": "yellow" },
                { "value": 50, "color": "green" }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "P95 Latency SLO (500ms)",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(app_http_request_duration_bucket[5m])) by (le))",
            "legendFormat": "P95 Latency"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 400, "color": "green" },
                { "value": 500, "color": "yellow" },
                { "value": 750, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Error Rate SLO (0.1%)",
        "type": "stat",
        "targets": [
          {
            "expr": "(\n  sum(rate(app_errors_total[5m]))\n  /\n  sum(rate(app_requests_total[5m]))\n) * 100",
            "legendFormat": "Error Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 0.05, "color": "green" },
                { "value": 0.1, "color": "yellow" },
                { "value": 0.5, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Availability Trend (30d)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "(\n  sum(rate(app_requests_total{status!~\"5..\"}[5m]))\n  /\n  sum(rate(app_requests_total[5m]))\n) * 100",
            "legendFormat": "Availability"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 20
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Latency Percentiles",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(app_http_request_duration_bucket[5m])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(app_http_request_duration_bucket[5m])) by (le))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(app_http_request_duration_bucket[5m])) by (le))",
            "legendFormat": "P99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Error Rate Trend",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(app_errors_total[5m])) / sum(rate(app_requests_total[5m])) * 100",
            "legendFormat": "Error Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 20
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Request Volume",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(app_requests_total[5m]))",
            "legendFormat": "Requests/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 9,
        "title": "SLO Status Summary",
        "type": "table",
        "targets": [
          {
            "expr": "(\n  sum(rate(app_requests_total{status!~\"5..\"}[5m]))\n  /\n  sum(rate(app_requests_total[5m]))\n) * 100",
            "legendFormat": "Availability",
            "format": "table"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(app_http_request_duration_bucket[5m])) by (le))",
            "legendFormat": "P95 Latency",
            "format": "table"
          },
          {
            "expr": "sum(rate(app_errors_total[5m])) / sum(rate(app_requests_total[5m])) * 100",
            "legendFormat": "Error Rate",
            "format": "table"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "Value": "Current",
                "Time": "Time"
              }
            }
          }
        ]
      }
    ],
    "time": {
      "from": "now-7d",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["30s", "1m", "5m"]
    }
  },
  "overwrite": true,
  "message": "SLO/SLI Compliance Dashboard"
}
