{
  "mcpServers": {
    "claude-flow@alpha": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "claude-flow@alpha",
        "mcp",
        "start"
      ]
    },
    "flow-nexus": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "flow-nexus@latest",
        "mcp",
        "start"
      ]
    },
    "agentic-payments": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "agentic-payments@latest",
        "mcp"
      ]
    }
  }
}