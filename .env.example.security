# AGL Infrastructure Security Configuration
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control

# ==============================================
# MCP SERVER SECURITY
# ==============================================
# Generate secure keys using: openssl rand -base64 64
MCP_LARAVEL_BOOST_KEY=
MCP_SHADCN_KEY=
MCP_RUV_SWARM_KEY=

# MCP Rate Limiting
MCP_RATE_LIMITING_ENABLED=true
MCP_RATE_LIMIT_MAX_ATTEMPTS=60
MCP_RATE_LIMIT_DECAY_MINUTES=1
MCP_RATE_LIMIT_PER_MINUTE=100

# MCP IP Whitelist (comma-separated CIDR blocks)
MCP_IP_WHITELIST_ENABLED=false
MCP_ALLOWED_IPS=10.6.0.0/24,192.168.0.0/24

# MCP Audit Logging
MCP_AUDIT_LOGGING_ENABLED=true
MCP_LOG_CHANNEL=mcp
MCP_LOG_REQUESTS=true
MCP_LOG_RESPONSES=false

# MCP Encryption
MCP_ENCRYPTION_ENABLED=true
MCP_ENCRYPTION_ALGORITHM=AES-256-GCM
# Generate with: openssl rand -base64 32
MCP_ENCRYPTION_KEY=

# MCP CORS (set to true only if needed)
MCP_CORS_ENABLED=false
MCP_CORS_ORIGINS=https://aglz.io,https://app.aglz.io

# ==============================================
# SECRETS MANAGEMENT (Vault)
# ==============================================
VAULT_ADDR=https://vault.aglz.io:8200
VAULT_TOKEN=
VAULT_NAMESPACE=agl

# ==============================================
# BACKUP ENCRYPTION
# ==============================================
# Generate GPG key: gpg --gen-key
BACKUP_GPG_RECIPIENT=admin@aglz.io
BACKUP_ENCRYPTION_ENABLED=true

# ==============================================
# TWO-FACTOR AUTHENTICATION
# ==============================================
# 2FA Configuration
GOOGLE2FA_ENABLED=true
GOOGLE2FA_SECRET=
GOOGLE2FA_ISSUER=AGL-Hostman

# ==============================================
# SECURITY MONITORING
# ==============================================
# Alert Thresholds
SECURITY_ALERT_FAILED_AUTH_THRESHOLD=5
SECURITY_ALERT_RATE_LIMIT_THRESHOLD=100
SECURITY_ALERT_VULNERABILITY_THRESHOLD=1

# Monitoring Webhook
SECURITY_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SECURITY_WEBHOOK_ENABLED=true

# ==============================================
# FIREWALL CONFIGURATION
# ==============================================
# Allowed Networks
VPN_NETWORK=10.6.0.0/24
INTERNAL_NETWORK=192.168.0.0/24
DMZ_NETWORK=10.6.0.0/24

# Blocked Countries (comma-separated ISO codes)
BLOCKED_COUNTRIES=

# ==============================================
# SECURITY HEADERS
# ==============================================
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=true

SECURITY_CSP_ENABLED=true
SECURITY_CSP_DIRECTIVE="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"

# ==============================================
# INCIDENT RESPONSE
# ==============================================
# Emergency Contacts
SECURITY_TEAM_EMAIL=security@aglz.io
INCIDENT_RESPONSE_EMAIL=incident@aglz.io
EMERGENCY_CONTACT=

# Incident Logging
INCIDENT_LOG_RETENTION_DAYS=365
INCIDENT_LOG_PATH=/var/log/agl/incidents

# ==============================================
# COMPLIANCE
# ==============================================
# GDPR Compliance
GDPR_ENABLED=true
GDPR_DATA_RETENTION_DAYS=365
GDPR_AUTO_DELETE=false

# SOC2 Compliance
SOC2_AUDIT_LOG_RETENTION_DAYS=2555  # 7 years
SOC2_ACCESS_LOG_ENABLED=true
SOC2_CHANGE_LOG_ENABLED=true

# ==============================================
# NOTES
# ==============================================
# 1. Generate all secrets using cryptographically secure methods:
#    - openssl rand -base64 32 (for 32-byte keys)
#    - openssl rand -hex 32 (for hex-encoded keys)
#    - uuidgen (for UUIDs)
#
# 2. Store credentials in HashiCorp Vault or equivalent:
#    vault kv put agl/prod/database username="user" password="..."
#
# 3. Rotate credentials regularly:
#    - Critical: Every 30 days
#    - High: Every 90 days
#    - Medium: Every 180 days
#
# 4. Enable MFA for all administrative access:
#    - HashiCorp Vault UI
#    - Proxmox web interface
#    - SSH keys
#
# 5. Monitor for security events:
#    - Failed authentication attempts
#    - Unusual access patterns
#    - Vulnerability scan results
#    - Firewall deny logs
