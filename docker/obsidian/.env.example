# Copiar para .env no CT193 (nunca commitar .env com passwords reais).
COUCHDB_USER=obsidian
COUCHDB_PASSWORD=change-me-strong-password
# Bind local por defeito; para LAN+Tailscale: 0.0.0.0 (restringir com firewall)
COUCHDB_BIND=127.0.0.1
# Unprivileged LXC: preferir path local (NFS /mnt/storage pode ser read-only ou uid mismatch)
COUCHDB_DATA_DIR=/var/lib/agl-obsidian/couchdb
