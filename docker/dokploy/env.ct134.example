# CT134 produção — variáveis (copiar para /opt/agl-hostman-prod/.env no CT134)
APP_NAME="AGL Hostman"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://ah.aglz.io

# Imagem (actualizada pelo pipeline / Dokploy)
IMAGE=harbor.aglz.io/agl-hostman-prod/hostman:prod-latest

# PostgreSQL CT149
DB_CONNECTION=pgsql
DB_HOST=192.168.0.149
DB_PORT=5432
DB_DATABASE=agl_hostman_prod
DB_USERNAME=agl_hostman
DB_PASSWORD=change-me

# Redis CT137
REDIS_HOST=192.168.0.137
REDIS_PORT=6379
REDIS_PASSWORD=change-me
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

LOG_CHANNEL=daily
LOG_LEVEL=warning

# LiteLLM / LLM Monitor (Argus)
LITELLM_GATEWAY_URL=http://192.168.0.186:4000
# LITELLM_MASTER_KEY=  # Dokploy secret / cofre — não commitar
# API_KEY=             # ingest Argus via X-API-Key (services.hostman.api_key)
# HARNESS_GOVERNOR_STATE_PATH=/var/log/hostman/quota-governor-state.json
# LLM_MONITOR_GOVERNOR_STATE_PATH=
# LLM_MONITOR_PROBE_MODEL=glm-4.7-flash
# LLM_MONITOR_SPEND_WARN_USD=80
