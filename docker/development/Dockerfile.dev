# Development Dockerfile for agl-hostman
# Optimized for fast rebuilds and hot reloading

FROM node:20-alpine

# Install development tools
RUN apk add --no-cache \
    git \
    vim \
    curl \
    bash \
    python3 \
    make \
    g++

# Install nodemon for hot reloading
RUN npm install -g nodemon

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev)
RUN npm ci --legacy-peer-deps

# Copy source code (will be mounted as volume in compose)
COPY . .

# Expose ports
EXPOSE 3000
EXPOSE 9229

# Development user (matches host user to avoid permission issues)
USER node

# Start with nodemon for hot reloading
CMD ["nodemon", "--inspect=0.0.0.0:9229", "src/dashboard/server.js"]
