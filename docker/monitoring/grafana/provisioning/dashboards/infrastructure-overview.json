    "panels": [
      {
        "collapsed": false,
        "datasource": "Prometheus",
        "gridPos": {
          "x": 0,
          "y": 0
        },
        "id": 1,
        "panels": [],
        "repeat": "job",
        "repeatDirection": "h",
        "targets": [
          {
            "expr": "up{job=~\"node|cadvisor|redis|mysql|proxmox\"}",
            "refId": "A",
            "textMode": "auto"
          }
        ],
        "title": "Cluster Health Status",
        "type": "stat"
      },
      {
        "datasource": "Prometheus",
        "gridPos": {
          "x": 0,
          "y": 6
        },
        "id": 2,
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "orientation": "auto",
          "textMode": "auto",
          "text": {
            "title": "Healthy",
            "value": "0"
          }
        },
        "pluginVersion": "11.0.0",
        "targets": [
          {
            "expr": "count(up{job=~\"node|cadvisor|redis|mysql|proxmox\"}) == 1",
            "refId": "A"
          }
        ],
        "title": "Healthy Exporters",
        "type": "gauge"
      },
      {
        "datasource": "Prometheus",
        "gridPos": {
          "x": 12,
          "y": 0
        },
        "id": 3,
        "targets": [
          {
            "expr": "avg(rate(node_cpu_seconds_total{mode!=\"idle\"}[5m])) * 100",
            "legendFormat": "{{ {{ $labels.instance }}}",
            "refId": "A"
          }
        ],
        "title": "CPU Usage",
        "type": "graph"
      },
      {
        "datasource": "Prometheus",
        "gridPos": {
          "x": 12,
          "y": 6
        },
        "id": 4,
        "targets": [
          {
            "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
            "legendFormat": "{{ {{ $labels.instance }}}",
            "refId": "A"
          }
        ],
        "title": "Memory Usage",
        "type": "graph"
      },
      {
        "datasource": "Prometheus",
        "gridPos": {
          "x": 0,
          "y": 12
        },
        "id": 5,
        "targets": [
          {
            "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
            "legendFormat": "{{ {{ $labels.instance }}} - {{ {{ $labels.mountpoint }}}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Percent Used",
            "min": 0,
            "max": 100
          }
        ],
        "title": "Disk Space",
        "type": "graph"
      },
      {
        "datasource": "Prometheus",
        "gridPos": {
          "x": 12,
          "y": 12
        },
        "id": 6,
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total[5m]) * 8",
            "legendFormat": "{{ {{ $labels.instance }}} RX",
            "refId": "A"
          },
          {
            "expr": "rate(node_network_transmit_bytes_total[5m]) * 8",
            "legendFormat": "{{ {{ $labels.instance }}} TX",
            "refId": "A"
          }
        ],
        "title": "Network Traffic",
        "type": "graph"
      },
      {
        "datasource": "Prometheus",
        "gridPos": {
          "x": 0,
          "y": 18
        },
        "id": 7,
        "targets": [
          {
            "expr": "up{job=~\".*mcp.*|mcp-servers\"}",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "title": "MCP Servers Health",
        "type": "table"
      },
      {
        "datasource": "Prometheus",
        "gridPos": {
          "x": 12,
          "y": 18
        },
        "id": 8,
        "options": {
          "showHeader": true
        },
        "pluginVersion": "11.0.0",
        "targets": [
          {
            "expr": "container_last_seen{namespace=\"agl\"}",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "title": "Container Status",
        "type": "table"
      },
      {
        "datasource": "Prometheus",
        "gridPos": {
          "x": 0,
          "y": 30
        },
        "id": 9,
        "targets": [
          {
            "expr": "sum(ALERTS{alertstate=\"firing\"}) by (alertname)",
            "refId": "A"
          }
        ],
        "title": "Alert Summary",
        "type": "stat"
      },
      {
        "datasource": "Prometheus",
        "gridPos": {
          "x": 12,
          "y": 30
        },
        "id": 10,
        "targets": [
          {
            "expr": "backup_sla_backup_success",
            "refId": "A"
          },
          {
            "expr": "backup_sla_rpo_compliant",
            "refId": "B"
          },
          {
            "expr": "backup_sla_rto_compliant",
            "refId": "C"
          }
        ],
        "title": "Backup Status",
        "type": "gauge"
      }
    ],
    "refresh": "30s",
