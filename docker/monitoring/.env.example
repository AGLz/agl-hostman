# Monitoring Stack Environment Variables
# AGL Hostman - Configuration Template

# Environment
ENVIRONMENT=development
DATACENTER=default
REGION=default
CLUSTER=agl-hostman

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_DB_PASSWORD=changeme_db_password

# SMTP Configuration (for Alertmanager email notifications)
SMTP_HOST=smtp.gmail.com:587
SMTP_FROM=alertmanager@agl-hostman.com
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true

# Slack Configuration (for Slack notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Slack Channels
CRITICAL_SLACK_CHANNEL=#alerts-critical
DBA_SLACK_CHANNEL=#alerts-database
OPS_SLACK_CHANNEL=#alerts-ops
SECURITY_SLACK_CHANNEL=#alerts-security
SRE_SLACK_CHANNEL=#alerts-sre
PLATFORM_SLACK_CHANNEL=#alerts-platform
ONCALL_SLACK_CHANNEL=#alerts-oncall
BUSINESS_SLACK_CHANNEL=#alerts-business

# Email Recipients
DEFAULT_EMAIL=ops@agl-hostman.com
CRITICAL_EMAIL=oncall@agl-hostman.com
DBA_EMAIL=dba@agl-hostman.com
OPS_EMAIL=ops@agl-hostman.com
SECURITY_EMAIL=security@agl-hostman.com
SRE_EMAIL=sre@agl-hostman.com
PLATFORM_EMAIL=platform@agl-hostman.com
ONCALL_EMAIL=oncall@agl-hostman.com
BUSINESS_EMAIL=business@agl-hostman.com

# PagerDuty Configuration
PAGERDUTY_SERVICE_KEY=your-pagerduty-integration-key

# Database Configuration (for exporters)
DB_DATABASE=agl_hostman
DB_USERNAME=agl_user
DB_PASSWORD=secret

# Redis Configuration
REDIS_PASSWORD=

# Prometheus Configuration
PROMETHEUS_LT_URL=

# AWS Configuration (for CloudWatch - optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Elasticsearch Configuration (optional)
ES_URL=http://elasticsearch:9200
ES_INDEX=agl-hostman-*

# InfluxDB Configuration (optional)
INFLUX_URL=http://influxdb:8086
INFLUX_DATABASE=telegraf
INFLUX_USER=admin
INFLUX_PASSWORD=admin

# Graphite Configuration (optional)
GRAPHITE_URL=http://graphite:8080

# External URLs
WEBHOOK_URL=http://localhost:8000/hooks/alerts

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Resource Limits
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=50GB
LOKI_RETENTION=720h

# Time zones
TZ=UTC
