{
  "name": "agl-hostman",
  "version": "1.0.0",
  "description": "AGL Infrastructure Management and Monitoring Dashboard",
  "main": "src/dashboard/server.js",
  "scripts": {
    "start": "node src/dashboard/server.js",
    "dev": "nodemon src/dashboard/server.js",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest --config tests/integration/jest.config.js --coverage",
    "test:e2e": "jest tests/e2e --coverage",
    "test:watch": "jest --watch",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "docker:build": "docker build -t agl-hostman:latest -f docker/production/Dockerfile .",
    "docker:build:dev": "docker build -t agl-hostman:dev -f docker/development/Dockerfile.dev .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart"
  },
  "keywords": [
    "proxmox",
    "infrastructure",
    "monitoring",
    "dashboard",
    "docker",
    "wireguard",
    "tailscale"
  ],
  "author": "AGL Infrastructure Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "dockerode": "^4.0.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.3",
    "nock": "^13.4.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
