{
  "name": "agl-hostman",
  "version": "1.0.0",
  "description": "AGL Infrastructure Management System",
  "main": "src/api/server.js",
  "scripts": {
    "start": "node src/api/server.js",
    "dev": "node --watch src/api/server.js",
    "build": "echo 'No build step required'",
    "test": "node --test tests/api/*.test.js",
    "test:integration:litellm": "node --test tests/integration/litellm-claude-flow.test.js",
    "test:all": "node --test tests/api/ && node --test tests/integration/litellm-claude-flow.test.js && node tests/hive-mind/test-hive-mind-integration.js",
    "test:e2e": "playwright test",
    "seed:user": "node scripts/seed-test-user.js",
    "migrate": "node src/database/migrate.js",
    "lint": "eslint src/api/ src/services/ tests/api/ --ext .js",
    "lint:fix": "eslint src/api/ src/services/ tests/api/ --ext .js --fix"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
