{
  "name": "agl-hostman",
  "version": "0.3.0",
  "description": "AGL Infrastructure Management - Host administration, monitoring, and automation tools for Proxmox-based infrastructure",
  "main": "src/greeting/index.js",
  "type": "commonjs",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:greeting": "jest tests/validation/greeting-system.test.js",
    "test:performance": "node tests/validation/greeting-performance-benchmark.js",
    "lint": "eslint src/**/*.js tests/**/*.js examples/**/*.js",
    "lint:fix": "eslint src/**/*.js tests/**/*.js examples/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"examples/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"examples/**/*.js\"",
    "demo:greeting": "node examples/greeting-demo.js",
    "docs:generate": "jsdoc -c jsdoc.json",
    "precommit": "npm run lint && npm run format:check && npm test",
    "prepare": "husky install || true"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aguileraz/agl-hostman.git"
  },
  "keywords": [
    "infrastructure",
    "proxmox",
    "host-management",
    "automation",
    "monitoring",
    "wireguard",
    "docker",
    "nfs",
    "homelab"
  ],
  "author": "Andre Guilherme <andre@aglz.io>",
  "license": "MIT",
  "engines": {
    "node": ">=18.20.8",
    "npm": ">=10.8.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "12.4.1",
    "bindings": "1.5.0",
    "chalk": "5.6.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "file-uri-to-path": "2.0.0",
    "helmet": "^7.1.0",
    "uuid": "13.0.0",
    "winston": "3.18.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^18.19.50",
    "dockerode": "^4.0.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-node": "^11.1.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.3",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "shadcn": "3.6.1",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!src/**/*.spec.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "verbose": true,
    "testTimeout": 10000
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "jest --bail --findRelatedTests"
    ]
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:node/recommended",
      "plugin:jest/recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "node/no-unsupported-features/es-syntax": "off",
      "node/no-missing-import": "off",
      "node/no-unpublished-require": "off"
    }
  },
  "packageManager": "pnpm@10.19.0+sha512.c9fc7236e92adf5c8af42fd5bf1612df99c2ceb62f27047032f4720b33f8eacdde311865e91c411f2774f618d82f320808ecb51718bfa82c060c4ba7c76a32b8"
}
