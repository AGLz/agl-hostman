{
  "name": "agl-hostman",
  "version": "1.0.0",
  "description": "AGL Infrastructure Management System",
  "main": "src/api/server.js",
  "scripts": {
    "start": "node src/api/server.js",
    "dev": "node --watch src/api/server.js",
    "build": "echo 'No build step required'",
    "test": "node --test tests/api/*.test.js tests/unit/*.test.js",
    "test:integration:litellm": "node --test tests/integration/litellm-claude-flow.test.js",
    "test:litellm:battery": "node scripts/litellm/litellm-full-battery.js",
    "test:litellm:battery:quick": "node scripts/litellm/litellm-full-battery.js --tier quick",
    "test:litellm:battery:dry": "node scripts/litellm/litellm-full-battery.js --dry-probe",
    "sync:litellm:opt": "bash scripts/litellm/sync-litellm-repo-to-opt.sh",
    "sync:litellm:opt:copy-only": "bash scripts/litellm/sync-litellm-repo-to-opt.sh --no-restart",
    "test:all": "node --test tests/api/ && node --test tests/integration/litellm-claude-flow.test.js && node tests/hive-mind/test-hive-mind-integration.js",
    "test:e2e": "NODE_ENV=test npx playwright test",
    "playwright:install": "NODE_ENV=development npx playwright install chromium",
    "test:e2e:falg": "PW_SKIP_WEBSERVER=1 NODE_ENV=test npx playwright test -c playwright.falg.config.js",
    "test:e2e:falg:www5-aglz": "PW_SKIP_WEBSERVER=1 PLAYWRIGHT_BASE_URL=https://www5.aglz.io NODE_ENV=test npx playwright test -c playwright.falg.config.js tests/e2e/falg/www5-aglz-login.spec.js",
    "test:e2e:ah": "PW_SKIP_WEBSERVER=1 PLAYWRIGHT_BASE_URL=https://ah.aglz.io npx playwright test tests/e2e/ah-hosted.spec.js",
    "test:e2e:ah-dev": "PW_SKIP_WEBSERVER=1 PLAYWRIGHT_BASE_URL=https://ah-dev.aglz.io npx playwright test tests/e2e/ah-hosted.spec.js",
    "test:e2e:evonexus": "PW_SKIP_WEBSERVER=1 NODE_ENV=test npx playwright test -c playwright.evonexus.config.js tests/e2e/evonexus-terminal-ws.spec.js",
    "seed:user": "node scripts/seed-test-user.js",
    "migrate": "node src/database/migrate.js",
    "lint": "eslint src/api/ src/services/ tests/api/ --ext .js",
    "lint:fix": "eslint src/api/ src/services/ tests/api/ --ext .js --fix"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.4.5",
    "fastify": "^5.9.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^8.57.0",
    "playwright": "^1.58.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "ajv": ">=8.18.0",
      "js-yaml": ">=4.2.0"
    }
  }
}
