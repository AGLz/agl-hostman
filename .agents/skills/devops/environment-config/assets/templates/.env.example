# Laravel Environment Configuration Template
# Copy this file to .env and fill in your values
# DO NOT commit files with real credentials to version control

# ============================================================================
# APPLICATION
# ============================================================================
APP_NAME="Laravel Application"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_MAINTENANCE_DRIVER=file

# ============================================================================
# LOGGING
# ============================================================================
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DAYS=14

# ============================================================================
# DATABASE (MySQL)
# ============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Alternative: SQLite (uncomment to use)
# DB_CONNECTION=sqlite
# DB_DATABASE=/path/to/database.sqlite

# ============================================================================
# REDIS (Cache & Queue)
# ============================================================================
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1

# ============================================================================
# CACHE & SESSION
# ============================================================================
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# ============================================================================
# QUEUE
# ============================================================================
QUEUE_CONNECTION=redis

# ============================================================================
# MAIL
# ============================================================================
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================================
# FILE STORAGE
# ============================================================================
FILESYSTEM_DISK=local

# AWS S3 (if using s3)
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=

# ============================================================================
# BROADCASTING
# ============================================================================
BROADCAST_CONNECTION=log
# BROADCAST_DRIVER=pusher
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=mt1

# ============================================================================
# THIRD-PARTY SERVICES
# ============================================================================

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Sentry (Error Tracking)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Bugsnag (Alternative Error Tracking)
BUGSNAG_API_KEY=

# Datadog (Monitoring)
DATADOG_API_KEY=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=

# Mapbox
MAPBOX_ACCESS_TOKEN=

# Twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ============================================================================
# SECURITY
# ============================================================================
SANCTUM_STATEFUL_DOMAINS=
SESSION_DOMAIN=

# ============================================================================
# VAPID (Push Notifications)
# ============================================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# ============================================================================
# PERFORMANCE
# ============================================================================
OPCACHE_ENABLE=1
