# ============================================================================
# Offsite Backup Replication Configuration
# ============================================================================
# This file contains configuration for the backup replication system
# Copy this file to replication-config.env and customize for your environment
#
# Security: This file contains sensitive information
# Permissions: Should be 600 (read/write by owner only)
# ============================================================================

# ----------------------------------------------------------------------------
# LOCAL BACKUP SOURCES
# ----------------------------------------------------------------------------

# Application backups location (from backup-agl-hostman.sh)
BACKUP_SOURCE_LOCAL="/mnt/shares/agl-hostman-backups"

# Proxmox backup location (VM/CT dumps)
BACKUP_SOURCE_PROXMOX="/spark/base/dump"

# Temporary directory for processing
BACKUP_TEMP="/tmp/backup-replication"

# ----------------------------------------------------------------------------
# BACKBLAZE B2 CONFIGURATION
# ----------------------------------------------------------------------------

# B2 Bucket name
B2_BUCKET="agl-hostman-backups"

# B2 Account ID (or set via environment: B2_ACCOUNT_ID)
# B2_ACCOUNT_ID=""

# B2 Application Key (or set via environment: B2_ACCOUNT_KEY)
# B2_ACCOUNT_KEY=""

# B2 Endpoint (usually US, can be eu for EU region)
B2_ENDPOINT="https://s3.us-west-001.backblazeb2.com"

# Remote path structure in B2
B2_PATH_DAILY="daily"
B2_PATH_WEEKLY="weekly"
B2_PATH_MONTHLY="monthly"
B2_PATH_PROXMOX="proxmox"

# ----------------------------------------------------------------------------
# HETZNER STORAGE BOX CONFIGURATION
# ----------------------------------------------------------------------------

# Hetzner Storage Box hostname (e.g., uXXXXXX.your-storagebox.de)
HETZNER_HOST="uXXXXXX.your-storagebox.de"

# Hetzner username (usually uXXXXXX)
HETZNER_USER="uXXXXXX"

# Hetzner SSH port (usually 23 for Storage Box)
HETZNER_PORT=23

# Remote path structure on Hetzner
HETZNER_PATH_DAILY="daily"
HETZNER_PATH_WEEKLY="weekly"
HETZNER_PATH_MONTHLY="monthly"
HETZNER_PATH_PROXMOX="proxmox"

# ----------------------------------------------------------------------------
# ENCRYPTION CONFIGURATION
# ----------------------------------------------------------------------------

# GPG recipient for encryption (email or key ID)
ENCRYPT_GPG_RECIPIENT="agl-backup@local"

# GPG key ID (optional, will be auto-detected if not set)
# ENCRYPT_GPG_KEY_ID=""

# Cipher algorithm (AES256 is recommended)
ENCRYPT_CIPHER="AES256"

# Compression algorithm for encrypted files
ENCRYPT_COMPRESS="ZLIB"

# Digest algorithm for key derivation
ENCRYPT_DIGEST="SHA512"

# Temporary directory for encryption operations
ENCRYPT_TEMP_DIR="${BACKUP_TEMP}/encrypt"

# ----------------------------------------------------------------------------
# BANDWIDTH CONTROL
# ----------------------------------------------------------------------------

# Bandwidth limit in KB/s (0 = unlimited)
# Recommended: 10240 (10 MB/s) for 100 Mbps uplink
# For faster connections: 25600 (25 MB/s) or 0 for unlimited
BANDWIDTH_LIMIT=10240

# ----------------------------------------------------------------------------
# RETENTION POLICY
# ----------------------------------------------------------------------------

# Number of daily backups to retain offsite
RETENTION_DAILY=7

# Number of weekly backups to retain offsite
RETENTION_WEEKLY=4

# Number of monthly backups to retain offsite
RETENTION_MONTHLY=12

# Maximum age of backups (in days) before cleanup
RETENTION_MAX_AGE=90

# ----------------------------------------------------------------------------
# RCLONE OPTIONS
# ----------------------------------------------------------------------------

# Number of parallel file transfers
RCLONE_TRANSFERS=4

# Number of file checkers
RCLONE_CHECKERS=8

# Buffer size for transfers (in MB)
RCLONE_BUFFER_SIZE=16

# ----------------------------------------------------------------------------
# RSYNC OPTIONS
# ----------------------------------------------------------------------------

# Rsync compression level (0-9)
RSYNC_COMPRESS_LEVEL=6

# Delete files on destination that don't exist on source
RSYNC_DELETE=true

# Verify file transfers with checksum
RSYNC_CHECKSUM=true

# ----------------------------------------------------------------------------
# NOTIFICATION CONFIGURATION
# ----------------------------------------------------------------------------

# Email address for alerts (requires mailutils/postfix)
ALERT_EMAIL="ops@yourcompany.com"

# Slack webhook URL for alerts
# SLACK_WEBHOOK="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# Notification triggers
NOTIFY_ON_SUCCESS=true
NOTIFY_ON_FAILURE=true
NOTIFY_ON_WARNING=true

# ----------------------------------------------------------------------------
# SCHEDULING
# ----------------------------------------------------------------------------

# Hour to run daily replication (0-23)
SCHEDULE_DAILY_HOUR=3

# Day of week for weekly replication (0-6, 0 = Sunday)
SCHEDULE_WEEKLY_DAY=0

# Day of month for monthly replication (1-31)
SCHEDULE_MONTHLY_DAY=1

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------

# Log directory
LOG_DIR="/var/log/backup-replication"

# Log retention (days)
LOG_RETENTION_DAYS=30

# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL="INFO"

# ----------------------------------------------------------------------------
# ADVANCED OPTIONS
# ----------------------------------------------------------------------------

# Verify backups after replication
VERIFY_AFTER_SYNC=true

# Test restore interval (in days)
TEST_RESTORE_INTERVAL=7

# Maximum retries for failed transfers
MAX_RETRIES=3

# Retry delay (in seconds)
RETRY_DELAY=60

# Enable parallel processing of backup types
PARALLEL_PROCESSING=true

# ----------------------------------------------------------------------------
# MONITORING INTEGRATION
# ----------------------------------------------------------------------------

# Prometheus push gateway for metrics
# PROMETHEUS_PUSHGATEWAY="http://localhost:9091/metrics/job/backup-replication"

# Health check endpoint
# HEALTH_CHECK_URL="https://hc-ping.com.com/your-uuid-here"

# ----------------------------------------------------------------------------
# BACKUP SELECTION
# ----------------------------------------------------------------------------

# Include patterns (glob)
INCLUDE_PATTERNS=(
    "*.sql.gz"
    "*.tar.gz"
    "*.vma.zst"
    "*.zst"
)

# Exclude patterns (glob)
EXCLUDE_PATTERNS=(
    "*.tmp"
    "*.log"
    "*.swp"
    ".DS_Store"
    "Thumbs.db"
    ".git/"
    "node_modules/"
    ".cache/"
)

# ----------------------------------------------------------------------------
# STORAGE LIMITS
# ----------------------------------------------------------------------------

# Maximum storage to use (in GB) before alerting
MAX_STORAGE_GB=1000

# Minimum free space required (in GB)
MIN_FREE_SPACE_GB=100

# ----------------------------------------------------------------------------
# INTEGRITY CHECKING
# ----------------------------------------------------------------------------

# Generate checksums for transferred files
GENERATE_CHECKSUMS=true

# Verify checksums after transfer
VERIFY_CHECKSUMS=true

# Checksum algorithm (md5, sha1, sha256)
CHECKSUM_ALGORITHM="sha256"

# ----------------------------------------------------------------------------
# END OF CONFIGURATION
# ----------------------------------------------------------------------------
# To customize this configuration:
# 1. Copy this file to replication-config.env
# 2. Uncomment and modify the values you need
# 3. Set proper permissions: chmod 600 replication-config.env
# 4. Test with: ./backup-replication.sh --dry-run
# ----------------------------------------------------------------------------
