# Copiar para agl-honcho-lxc.env antes de pct-create-agl-honcho.sh

export CT_HONCHO_VMID=192
export CT_HONCHO_HOSTNAME=agl-honcho
export CT_HONCHO_MEMORY_MB=8192
export CT_HONCHO_SWAP_MB=1024
export CT_HONCHO_CORES=4
export CT_HONCHO_DISK_GB=48

export PROXMOX_BRIDGE=vmbr0
export PROXMOX_ROOTFS_STORAGE=local-zfs
export PROXMOX_TEMPLATE=local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst

# LiteLLM CT186 Tailscale (Deriver/Dialectic)
export LITELLM_TAILSCALE_URL=http://100.125.249.8:4000/v1
