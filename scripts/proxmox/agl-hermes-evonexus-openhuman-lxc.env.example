# Copiar para agl-hermes-evonexus-openhuman-lxc.env e fazer source antes de pct-create.
# Ex.: set -a && source agl-hermes-evonexus-openhuman-lxc.env && set +a && bash pct-create-agl-hermes-evonexus-openhuman.sh

export CT_HERMES_VMID=188
export CT_EVONEXUS_VMID=189
export CT_OPENHUMAN_VMID=190

export PROXMOX_BRIDGE=vmbr0
# AGLSRV1: local-zfs (CT186/187); ajustar se o nó usar local-lvm
export PROXMOX_ROOTFS_STORAGE=local-zfs
export PROXMOX_TEMPLATE=local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst

# Hermes Agent (Docker gateway + /opt/data)
export CT_HERMES_MEMORY_MB=8192
export CT_HERMES_SWAP_MB=1024
export CT_HERMES_CORES=4
export CT_HERMES_DISK_GB=32
export CT_HERMES_HOSTNAME=agl-hermes

# EvoNexus (hub Docker: dashboard + scheduler + telegram)
export CT_EVONEXUS_MEMORY_MB=16384
export CT_EVONEXUS_SWAP_MB=2048
export CT_EVONEXUS_CORES=8
export CT_EVONEXUS_DISK_GB=64
export CT_EVONEXUS_HOSTNAME=agl-evonexus

# OpenHuman (install nativo + dados em /opt/openhuman; UI desktop opcional)
export CT_OPENHUMAN_MEMORY_MB=8192
export CT_OPENHUMAN_SWAP_MB=1024
export CT_OPENHUMAN_CORES=4
export CT_OPENHUMAN_DISK_GB=48
export CT_OPENHUMAN_HOSTNAME=agl-openhuman

# LiteLLM canónico (CT186) — usado nos bootstraps
export LITELLM_LAN_URL=http://192.168.0.186:4000
