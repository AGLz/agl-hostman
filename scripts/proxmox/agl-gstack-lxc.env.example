# Copiar para agl-gstack-lxc.env e source antes de pct-create-ct191-agl-gstack.sh

export CT_GSTACK_VMID=191
export PROXMOX_BRIDGE=vmbr0
export PROXMOX_ROOTFS_STORAGE=local-zfs
export PROXMOX_TEMPLATE=local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst

# OpenClaw + GStack + Chromium (Jarvis O / AGLz Agency)
export CT_GSTACK_MEMORY_MB=16384
export CT_GSTACK_SWAP_MB=2048
export CT_GSTACK_CORES=8
export CT_GSTACK_DISK_GB=64
export CT_GSTACK_HOSTNAME=agl-gstack

export LITELLM_LAN_URL=http://192.168.0.186:4000
