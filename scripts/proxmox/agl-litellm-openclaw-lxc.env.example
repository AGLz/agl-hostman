# Copiar para agl-litellm-openclaw-lxc.env e fazer source antes de pct-create-agl-litellm-openclaw.sh
# Ex.: set -a && source agl-litellm-openclaw-lxc.env && set +a && bash pct-create-agl-litellm-openclaw.sh

# VMIDs (confirmar livres no nó; 150/151 costumam ser VMs QEMU em AGLSRV1)
export CT_LITELLM_VMID=186
export CT_OPENCLAW_VMID=187

# Rede / armazenamento Proxmox
export PROXMOX_BRIDGE=vmbr0
export PROXMOX_ROOTFS_STORAGE=local-lvm
export PROXMOX_TEMPLATE=local:vztmpl/debian-12-standard_amd64.tar.zst

# Recursos por CT
export CT_MEMORY_MB=8192
export CT_SWAP_MB=1024
export CT_CORES=4
export CT_DISK_GB=32

# Hostnames DNS internos
export CT_LITELLM_HOSTNAME=agl-litellm
export CT_OPENCLAW_HOSTNAME=agl-openclaw
