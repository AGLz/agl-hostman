{
  "env": {
    "browser": true,
    "es2022": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off"
  },
  "globals": {
    "SwaggerUIBundle": "readonly",
    "SwaggerUIStandalonePreset": "readonly",
    "Redoc": "readonly",
    "Prism": "readonly"
  }
}
