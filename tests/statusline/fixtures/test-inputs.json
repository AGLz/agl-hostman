          "domainsCompleted": 3,
          "totalDomains": 5
        }
      }
    },
    "complete_progress": {
      "description": "Complete V3 progress (5/5)",
      "input": {
        "v3Progress": {
          "domainsCompleted": 5,
          "totalDomains": 5
        }
      }
    },
    "with_swarm": {
      "description": "With active swarm agents",
      "input": {
        "swarm": {
          "activeAgents": 5
        }
      }
    },
    "with_intelligence": {
      "description": "With intelligence metric",
      "input": {
        "system": {
          "intelligencePct": 85
        }
      }
    },
    "security_clean": {
      "description": "Security status clean",
      "input": {
        "security": {
