          "status": "IN_PROGRESS"
        }
      }
    }
  },
  "environment_types": {
    "wsl2": {
      "description": "WSL2 environment",
      "indicator": "WSL2"
    },
    "docker": {
      "description": "Docker container",
      "indicator": "🐳"
    },
    "native_linux": {
      "description": "Native Linux environment",
      "indicator": null
    }
  }
}
