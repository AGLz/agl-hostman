# AGL Infrastructure Management - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ==============================================
# ARCHON CONFIGURATION
# ==============================================

# Archon Basic Authentication
# Used for public HTTPS access (https://archon.aglz.io)
ARCHON_USERNAME=admin
ARCHON_PASSWORD=<YOUR_SECURE_PASSWORD>

# Archon API Configuration
ARCHON_API_URL=https://archon.aglz.io
ARCHON_MCP_URL_WG=http://10.6.0.21:8051/mcp
ARCHON_MCP_URL_TS=http://100.80.30.59:8051/mcp

# ==============================================
# HARBOR CONFIGURATION
# ==============================================

# Harbor Registry
HARBOR_URL=harbor.aglz.io:5000
HARBOR_ADMIN_PASSWORD=<YOUR_SECURE_PASSWORD>

# Harbor API
HARBOR_API_URL=https://192.168.0.182/api/v2.0

# ==============================================
# SUPABASE CONFIGURATION (for Archon)
# ==============================================

SUPABASE_URL=<YOUR_SUPABASE_URL>
SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY>

# ==============================================
# OPENAI CONFIGURATION (for Archon embeddings)
# ==============================================

OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# ==============================================
# GRAFANA CONFIGURATION
# ==============================================

GRAFANA_ADMIN_PASSWORD=<YOUR_SECURE_PASSWORD>
GRAFANA_API_KEY=<YOUR_GRAFANA_API_KEY>

# ==============================================
# PROMETHEUS CONFIGURATION
# ==============================================

PROMETHEUS_TOKEN=<YOUR_PROMETHEUS_TOKEN>

# ==============================================
# GITHUB CONFIGURATION
# ==============================================

GITHUB_TOKEN=<YOUR_GITHUB_TOKEN>
GITHUB_WEBHOOK_SECRET=<YOUR_WEBHOOK_SECRET>

# ==============================================
# CLAUDE CODE / CLAUDE FLOW
# ==============================================

ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>

# ==============================================
# NOTES
# ==============================================

# Security Best Practices:
# 1. Use strong, unique passwords (minimum 16 characters)
# 2. Store production credentials in a secure vault (1Password, Bitwarden, etc.)
# 3. Rotate credentials regularly (every 90 days recommended)
# 4. Never commit .env files to version control
# 5. Use different credentials for dev/staging/production

# Password Requirements:
# - Minimum 16 characters
# - Mix of uppercase, lowercase, numbers, symbols
# - No dictionary words
# - No personal information

# Example Strong Password Generation:
# openssl rand -base64 32
# pwgen -s 32 1
# 1password generate --length 32
