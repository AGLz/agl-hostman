# Environment Configuration for agl-hostman
# Copy this file to .env and fill in your values

# ============================================================================
# Application Configuration
# ============================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ============================================================================
# Proxmox API Configuration
# ============================================================================
# Primary Proxmox host (AGLSRV1)
PROXMOX_HOST=192.168.0.245
PROXMOX_PORT=8006
PROXMOX_USER=root@pam

# API Token (recommended over password)
# Create token in Proxmox: Datacenter -> Permissions -> API Tokens
PROXMOX_TOKEN_ID=your-token-id
PROXMOX_TOKEN_SECRET=your-token-secret

# Alternative: Username/Password (less secure, not recommended)
# PROXMOX_PASSWORD=your-password

# Secondary Proxmox host (AGLSRV6)
PROXMOX_SECONDARY_HOST=10.6.0.12
PROXMOX_SECONDARY_PORT=8006
PROXMOX_SECONDARY_USER=root@pam
PROXMOX_SECONDARY_TOKEN_ID=your-secondary-token-id
PROXMOX_SECONDARY_TOKEN_SECRET=your-secondary-token-secret

# ============================================================================
# Network Configuration
# ============================================================================
# WireGuard Mesh Network
WIREGUARD_ENABLED=true
WIREGUARD_INTERFACE=wg0
WIREGUARD_NETWORK=10.6.0.0/24

# Tailscale VPN
TAILSCALE_ENABLED=true

# ============================================================================
# Dashboard Configuration
# ============================================================================
REFRESH_INTERVAL=30000          # Data refresh interval (ms)
ENABLE_REALTIME_UPDATES=true    # WebSocket updates
MAX_HISTORY_POINTS=100          # Chart history points

# ============================================================================
# Monitoring Configuration
# ============================================================================
HEALTH_CHECK_INTERVAL=60000     # Health check interval (ms)
ALERT_THRESHOLD_CPU=90          # CPU alert threshold (%)
ALERT_THRESHOLD_MEMORY=85       # Memory alert threshold (%)
ALERT_THRESHOLD_DISK=80         # Disk alert threshold (%)

# ============================================================================
# Storage Configuration
# ============================================================================
# NFS Storage Monitoring
NFS_MOUNTS=/mnt/pve/fgsrv6-wg,/mnt/pve/ct111-shares,/mnt/pve/aglsrv6-bb

# ============================================================================
# Security Configuration
# ============================================================================
# Dashboard Authentication (optional)
ENABLE_AUTH=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# CORS Configuration
CORS_ORIGIN=*
CORS_METHODS=GET,POST

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_FORMAT=json                 # json or text
LOG_FILE_PATH=/app/logs/app.log
LOG_MAX_SIZE=10m                # Max log file size
LOG_MAX_FILES=5                 # Max log files to keep

# ============================================================================
# Integration Configuration
# ============================================================================
# Archon AI Command Center
ARCHON_ENABLED=false
ARCHON_HOST=10.6.0.21
ARCHON_PORT=8051

# Docker Registry (Harbor)
HARBOR_ENABLED=false
HARBOR_URL=https://harbor.aglz.io
HARBOR_USERNAME=admin
HARBOR_PASSWORD=changeme
